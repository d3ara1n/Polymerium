<app:WidgetBase
    x:Class="Polymerium.App.Widgets.DummyWidget"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Dummy"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <app:WidgetBase.FullTemplate>
        <DataTemplate x:DataType="app:DummyWidget">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.7"
                Text="This is Dummy Widget" />
        </DataTemplate>
    </app:WidgetBase.FullTemplate>
    <app:WidgetBase.SlimTemplate>
        <DataTemplate x:DataType="app:DummyWidget">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.7"
                Text="This is Dummy Widget" />
        </DataTemplate>
    </app:WidgetBase.SlimTemplate>
</app:WidgetBase>
