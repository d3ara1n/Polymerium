<husk:Dialog
    x:Class="Polymerium.App.Dialogs.ModpackExporterDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Static lang:Resources.ModpackExporterDialog_Title}"
    Width="450"
    d:DesignHeight="600"
    IsPrimaryButtonVisible="True"
    mc:Ignorable="d">
    <StackPanel Spacing="24">
        <!--  格式选择  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_FormatLabelText}" />
            <TabStrip
                ItemsSource="{Binding $parent[app:ModpackExporterDialog].ExporterLabels, Mode=OneWay, FallbackValue={x:Null}}"
                SelectedItem="{Binding $parent[app:ModpackExporterDialog].SelectedExporterLabel, Mode=TwoWay, FallbackValue={x:Null}}">
                <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <husk:IconLabel
                            Icon="FolderZip"
                            Text="{Binding Converter={x:Static husk:StringConverters.ToUpper}}" />
                    </DataTemplate>
                </TabStrip.ItemTemplate>
            </TabStrip>
        </StackPanel>
        <!--  基本选项  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_NameLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[app:ModpackExporterDialog].NameOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[app:ModpackExporterDialog].NameOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Tag" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AuthorLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[app:ModpackExporterDialog].AuthorOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[app:ModpackExporterDialog].AuthorOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Person" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_VersionLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[app:ModpackExporterDialog].VersionOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[app:ModpackExporterDialog].VersionOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Branch" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
        </StackPanel>
        <!--  额外选项  -->
        <Expander Header="{x:Static lang:Resources.ModpackExporterDialog_AdvancedOptionsLabelText}">
            <StackPanel Spacing="8">
                <DockPanel>
                    <Button
                        DockPanel.Dock="Right"
                        Classes="Small"
                        Command="{Binding $parent[app:ModpackExporterDialog].AddTagCommand}"
                        Theme="{StaticResource GhostButtonTheme}">
                        <husk:IconLabel
                            Icon="Add"
                            Text="{x:Static lang:Resources.InstancePackageModal_AddTagButtonText}" />
                    </Button>
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_ExcludedTagsLabelText}" />
                </DockPanel>
                <app:EmptyContainer
                    Icon="TagMultiple"
                    IsEmpty="{Binding $parent[app:ModpackExporterDialog].PackData.ExcludedTags.Count, Converter={x:Static husk:NumberConverters.IsZero}, FallbackValue=False}">
                    <ItemsControl ItemsSource="{Binding $parent[app:ModpackExporterDialog].PackData.ExcludedTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel
                                    ItemSpacing="6"
                                    LineSpacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Background="{StaticResource ControlAccentTranslucentFullBackgroundBrush}"
                                    BorderBrush="{StaticResource ControlAccentInteractiveBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource SmallCornerRadius}">
                                    <DockPanel>
                                        <Button
                                            DockPanel.Dock="Right"
                                            Padding="4,0"
                                            Command="{Binding $parent[app:ModpackExporterDialog].RemoveTagCommand}"
                                            CommandParameter="{Binding}"
                                            CornerRadius="{husk:StaticResourceBinding SmallCornerRadius,
                                                                                      Converter={x:Static husk:CornerRadiusConverters.Right}}"
                                            Theme="{StaticResource GhostButtonTheme}">
                                            <fi:SymbolIcon
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontSize="{Binding $parent[Button].FontSize}"
                                                Symbol="Dismiss" />
                                        </Button>
                                        <TextBlock
                                            Margin="8,4,0,4"
                                            Text="{Binding}" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </app:EmptyContainer>
                <TextBlock
                    FontSize="{StaticResource SmallFontSize}"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="{x:Static lang:Resources.ModpackExporterDialog_ExcludedTagsDescriptionText}" />
            </StackPanel>
        </Expander>
        <!--  Trident 专属选项  -->
        <Expander Header="{x:Static lang:Resources.ModpackExporterDialog_TridentOptionsLabelText}">
            <StackPanel Spacing="8">
                <husk:InfoBar
                    Classes="Warning"
                    IsVisible="{Binding $parent[app:ModpackExporterDialog].SelectedExporterLabel, Converter={x:Static husk:ObjectConverters.NotMatch}, ConverterParameter=trident}"
                    Content="{x:Static lang:Resources.ModpackExporterDialog_TridentOptionsInfoBarText}" />
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[app:ModpackExporterDialog].PackData.IncludingSource, FallbackValue=false}" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="6">
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{x:Static lang:Resources.ModpackExporterDialog_IncludingSourceLabelText}" />
                        <fi:SymbolIcon
                            VerticalAlignment="Center"
                            Background="Transparent"
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Info"
                            ToolTip.Tip="{x:Static lang:Resources.ModpackExporterDialog_IncludingSourceToolTip}" />
                    </StackPanel>
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[app:ModpackExporterDialog].PackData.IncludingTags, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_IncludingTagsLabelText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[app:ModpackExporterDialog].PackData.ConnectServer, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_ConnectServerText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[app:ModpackExporterDialog].PackData.JavaMaxMemory, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_JavaMaxMemoryLabelText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[app:ModpackExporterDialog].PackData.JavaAdditionalArguments, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_JavaAdditionalArgumentsLabelText}" />
                </DockPanel>

            </StackPanel>
        </Expander>
        <!--  附件  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsLabelText}" />
            <Border
                Padding="3"
                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <Border
                    Padding="8"
                    Background="{StaticResource OverlaySolidBackgroundBrush}">
                    <Border.CornerRadius>
                        <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                            <Binding
                                Path="CornerRadius"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                            <Binding
                                Path="Padding"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                        </MultiBinding>
                    </Border.CornerRadius>
                    <Grid
                        ColumnDefinitions="*,Auto,*"
                        ColumnSpacing="8">
                        <Grid
                            Grid.Column="0"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="8">
                            <Image
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                RenderOptions.BitmapInterpolationMode="MediumQuality"
                                Source="/Assets/Icons/Package.png" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.ModpackExporterDialog_PackagesLabelText}" />
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    Text="{Binding $parent[app:ModpackExporterDialog].PackageCount, FallbackValue=Unknown}" />
                            </StackPanel>
                        </Grid>
                        <husk:Divider
                            Grid.Column="1"
                            Orientation="Vertical" />
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.ModpackExporterDialog_ModLoaderLabelText}" />
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                Text="{Binding $parent[app:ModpackExporterDialog].LoaderLabel, FallbackValue=Unknown}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
            <StackPanel Spacing="4">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="6">
                    <fi:SymbolIcon
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Symbol="Info" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                        <Run Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsPrompt}" />
                        <HyperlinkButton Command="{Binding $parent[app:ModpackExporterDialog].OpenImportFolderCommand}">
                            <TextBlock Text="./import" />
                        </HyperlinkButton>
                    </TextBlock>
                </StackPanel>
                <HyperlinkButton
                    Classes="Small"
                    VerticalAlignment="Center"
                    Command="{x:Static app:InternalCommands.OpenStringUriCommand}"
                    CommandParameter="https://github.com/d3ara1n/Polymerium/wiki/%E6%95%B4%E5%90%88%E5%8C%85">
                    <husk:IconLabel
                        FontSize="{StaticResource SmallFontSize}"
                        Icon="BookQuestionMark"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_OpenWikiButtonText}" />
                </HyperlinkButton>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</husk:Dialog>
