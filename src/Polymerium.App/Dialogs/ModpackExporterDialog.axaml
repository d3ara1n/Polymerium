<husk:Dialog
    x:Class="Polymerium.App.Dialogs.ModpackExporterDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Polymerium.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:local="clr-namespace:Polymerium.App.Dialogs"
    xmlns:m="using:Polymerium.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Static lang:Resources.ModpackExporterDialog_Title}"
    Width="450"
    d:DesignHeight="600"
    IsPrimaryButtonVisible="True"
    mc:Ignorable="d">
    <StackPanel Spacing="24">
        <!--  格式选择  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_FormatLabelText}" />
            <TabStrip
                ItemsSource="{Binding $parent[local:ModpackExporterDialog].ExporterLabels, Mode=OneWay, FallbackValue={x:Null}}"
                SelectedItem="{Binding $parent[local:ModpackExporterDialog].SelectedExporterLabel, Mode=TwoWay, FallbackValue={x:Null}}">
                <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <husk:IconLabel
                            Icon="FolderZip"
                            Text="{Binding Converter={x:Static husk:StringConverters.ToUpper}}" />
                    </DataTemplate>
                </TabStrip.ItemTemplate>
            </TabStrip>
        </StackPanel>
        <!--  基本选项  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_NameLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[local:ModpackExporterDialog].NameOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[local:ModpackExporterDialog].NameOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Tag" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AuthorLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[local:ModpackExporterDialog].AuthorOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[local:ModpackExporterDialog].AuthorOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Person" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_VersionLabelText}" />
            <TextBox
                PlaceholderText="{Binding $parent[local:ModpackExporterDialog].VersionOriginal, FallbackValue=Unknown}"
                Text="{Binding $parent[local:ModpackExporterDialog].VersionOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Branch" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
        </StackPanel>
        <!--  额外选项  -->
        <Expander Header="{x:Static lang:Resources.ModpackExporterDialog_AdvancedOptionsLabelText}">
            <StackPanel Spacing="8">
                <husk:InfoBar
                    Classes="Warning"
                    IsVisible="{Binding $parent[local:ModpackExporterDialog].SelectedExporterLabel, Converter={x:Static husk:ObjectConverters.NotMatch}, ConverterParameter=trident}"
                    Content="{x:Static lang:Resources.ModpackExporterDialog_AdvancedOptionsInfoBarText}" />
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[local:ModpackExporterDialog].PackData.IncludingSource, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_IncludingSourceLabelText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[local:ModpackExporterDialog].PackData.IncludingTags, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_IncludingTagsLabelText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[local:ModpackExporterDialog].PackData.ConnectServer, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_ConnectServerText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[local:ModpackExporterDialog].PackData.JavaMaxMemory, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_JavaMaxMemoryLabelText}" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        IsChecked="{Binding $parent[local:ModpackExporterDialog].PackData.JavaAdditionalArguments, FallbackValue=false}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_JavaAdditionalArgumentsLabelText}" />
                </DockPanel>

            </StackPanel>
        </Expander>
        <!--  附件  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsLabelText}" />
            <Border
                Padding="3"
                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <Border
                    Padding="8"
                    Background="{StaticResource OverlaySolidBackgroundBrush}">
                    <Border.CornerRadius>
                        <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                            <Binding
                                Path="CornerRadius"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                            <Binding
                                Path="Padding"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                        </MultiBinding>
                    </Border.CornerRadius>
                    <Grid
                        ColumnDefinitions="*,Auto,*"
                        ColumnSpacing="8">
                        <Grid
                            Grid.Column="0"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="8">
                            <Image
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                RenderOptions.BitmapInterpolationMode="MediumQuality"
                                Source="/Assets/Icons/Package.png" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.ModpackExporterDialog_PackagesLabelText}" />
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    Text="{Binding $parent[local:ModpackExporterDialog].PackageCount, FallbackValue=Unknown}" />
                            </StackPanel>
                        </Grid>
                        <husk:Divider
                            Grid.Column="1"
                            Orientation="Vertical" />
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.ModpackExporterDialog_ModLoaderLabelText}" />
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                Text="{Binding $parent[local:ModpackExporterDialog].LoaderLabel, FallbackValue=Unknown}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
            <StackPanel Spacing="4">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="6">
                    <fi:SymbolIcon
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Symbol="Info" />
                    <TextBlock Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                        <Run Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsPrompt}" />
                        <HyperlinkButton Command="{Binding $parent[local:ModpackExporterDialog].OpenImportFolderCommand}">
                            <TextBlock Text="./import" />
                        </HyperlinkButton>
                    </TextBlock>
                </StackPanel>
                <HyperlinkButton
                    Classes="Small"
                    VerticalAlignment="Center"
                    Command="{x:Static m:InternalCommands.OpenStringUriCommand}"
                    CommandParameter="https://github.com/d3ara1n/Polymerium/wiki/%E6%95%B4%E5%90%88%E5%8C%85">
                    <husk:IconLabel
                        Icon="BookQuestionMark"
                        Text="{x:Static lang:Resources.ModpackExporterDialog_OpenWikiButtonText}" />
                </HyperlinkButton>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</husk:Dialog>
