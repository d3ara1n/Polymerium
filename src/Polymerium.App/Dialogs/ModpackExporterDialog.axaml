<husk:Dialog
    x:Class="Polymerium.App.Dialogs.ModpackExporterDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Polymerium.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:icons="https://github.com/MahApps/IconPacks.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:local="clr-namespace:Polymerium.App.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Static lang:Resources.ModpackExporterDialog_Title}"
    Width="450"
    d:DesignHeight="600"
    IsPrimaryButtonVisible="True"
    mc:Ignorable="d">
    <StackPanel Spacing="24">
        <!--  格式选择  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_FormatLabelText}" />
            <TabStrip
                ItemsSource="{Binding $parent[local:ModpackExporterDialog].ExporterLabels, Mode=OneWay, FallbackValue={x:Null}}"
                SelectedItem="{Binding $parent[local:ModpackExporterDialog].SelectedExporterLabel, Mode=TwoWay, FallbackValue={x:Null}}">
                <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <husk:IconLabel
                            Icon="FolderZip"
                            Text="{Binding Converter={x:Static husk:StringConverters.ToUpper}}" />
                    </DataTemplate>
                </TabStrip.ItemTemplate>
            </TabStrip>
        </StackPanel>
        <!--  基本选项  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_NameLabelText}" />
            <TextBox
                Text="{Binding $parent[local:ModpackExporterDialog].NameOverride, Mode=TwoWay, FallbackValue={x:Null}}"
                Watermark="{Binding $parent[local:ModpackExporterDialog].NameOriginal, FallbackValue=Unknown}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <icons:PackIconLucide
                            Height="{StaticResource MediumFontSize}"
                            Margin="12,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Kind="Tag" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AuthorLabelText}" />
            <TextBox
                Text="{Binding $parent[local:ModpackExporterDialog].AuthorOverride, Mode=TwoWay, FallbackValue={x:Null}}"
                Watermark="{Binding $parent[local:ModpackExporterDialog].AuthorOriginal, FallbackValue=Unknown}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <icons:PackIconLucide
                            Height="{StaticResource MediumFontSize}"
                            Margin="12,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Kind="User" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_VersionLabelText}" />
            <TextBox
                Text="{Binding $parent[local:ModpackExporterDialog].VersionOverride, Mode=TwoWay, FallbackValue={x:Null}}"
                Watermark="{Binding $parent[local:ModpackExporterDialog].VersionOriginal, FallbackValue=Unknown}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <icons:PackIconLucide
                            Height="{StaticResource MediumFontSize}"
                            Margin="12,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Kind="GitBranch" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
            </TextBox>
        </StackPanel>
        <!--  额外选项  -->
        <Expander Header="额外选项">
            <StackPanel Spacing="8">
                <husk:InfoBar
                    Classes="Warning"
                    IsVisible="{Binding $parent[local:ModpackExporterDialog].SelectedExporterLabel, Converter={x:Static husk:ObjectConverters.NotMatch}, ConverterParameter=trident}"
                    Content="这些选项只有在导出为 Trident Portable Instance 时才有作用" />
                <DockPanel>
                    <ToggleSwitch DockPanel.Dock="Right" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="保留来源信息" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch DockPanel.Dock="Right" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="包含服务器连接设置" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch DockPanel.Dock="Right" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="包含 JVM 最大内存设置" />
                </DockPanel>
                <DockPanel>
                    <ToggleSwitch DockPanel.Dock="Right" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="包含 JVM 附加参数设置" />
                </DockPanel>

            </StackPanel>
        </Expander>
        <!--  附件  -->
        <StackPanel Spacing="8">
            <TextBlock
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsLabelText}" />
            <Border
                Padding="3"
                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <Border
                    Padding="8"
                    Background="{StaticResource OverlaySolidBackgroundBrush}">
                    <Border.CornerRadius>
                        <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                            <Binding
                                Path="CornerRadius"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                            <Binding
                                Path="Padding"
                                RelativeSource="{RelativeSource FindAncestor,
                                                                AncestorType=Border}" />
                        </MultiBinding>
                    </Border.CornerRadius>
                    <Grid
                        ColumnDefinitions="*,Auto,*"
                        ColumnSpacing="8">
                        <Grid
                            Grid.Column="0"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="8">
                            <Image
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                RenderOptions.BitmapInterpolationMode="MediumQuality"
                                Source="/Assets/Icons/Package.png" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.ModpackExporterDialog_PackagesLabelText}" />
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    Text="{Binding $parent[local:ModpackExporterDialog].PackageCount, FallbackValue=Unknown}" />
                            </StackPanel>
                        </Grid>
                        <husk:Divider
                            Grid.Column="1"
                            Orientation="Vertical" />
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.ModpackExporterDialog_ModLoaderLabelText}" />
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                Text="{Binding $parent[local:ModpackExporterDialog].LoaderLabel, FallbackValue=Unknown}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
            <StackPanel
                Orientation="Horizontal"
                Spacing="6">
                <fi:SymbolIcon
                    FontSize="{StaticResource MediumFontSize}"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Symbol="Info" />
                <TextBlock Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                    <Run Text="{x:Static lang:Resources.ModpackExporterDialog_AttachmentsPrompt}" />
                    <HyperlinkButton Command="{Binding $parent[local:ModpackExporterDialog].OpenImportFolderCommand}">
                        <TextBlock Text="./import" />
                    </HyperlinkButton>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</husk:Dialog>
