<husk:Dialog
    x:Class="Polymerium.App.Dialogs.RuntimePickerDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Static lang:Resources.RuntimePickerDialog_Title}"
    Width="640"
    d:DesignHeight="420"
    d:DesignWidth="640"
    x:DataType="app:RuntimePickerDialogModel"
    IsPrimaryButtonVisible="True"
    Message="{x:Static lang:Resources.RuntimePickerDialog_Prompt}"
    mc:Ignorable="d">
    <husk:PlaceholderContainer Source="{Binding Candidates}">
        <StackPanel
            MinHeight="180"
            VerticalAlignment="Center"
            Spacing="12">
            <ProgressBar
                Width="220"
                HorizontalAlignment="Center"
                IsIndeterminate="True" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.RuntimePickerDialog_LoadingText}" />
        </StackPanel>
        <husk:PlaceholderContainer.SourceTemplate>
            <DataTemplate x:DataType="app:RuntimePickerDialogCandidateCollection">
                <Grid RowDefinitions="*,Auto">
                    <app:EmptyContainer
                        Icon="DrinkCoffee"
                        IsEmpty="{Binding Count, Converter={x:Static husk:NumberConverters.IsZero}, FallbackValue=True}">
                        <ListBox
                            MinHeight="180"
                            MaxHeight="360"
                            ItemsSource="{Binding Items}"
                            SelectedItem="{Binding $parent[app:RuntimePickerDialog].Result, Mode=OneWayToSource}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="app:RuntimePickerDialogCandidateModel">
                                    <Grid
                                        ColumnDefinitions="Auto,*,Auto"
                                        ColumnSpacing="12"
                                        RowDefinitions="Auto,Auto"
                                        RowSpacing="4">
                                        <Border
                                            Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="0"
                                            Width="44"
                                            Height="44"
                                            Background="{StaticResource ControlTranslucentHalfBackgroundBrush}"
                                            CornerRadius="{StaticResource SmallCornerRadius}">
                                            <husk:PlaceholderContainer
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{Binding Major}">
                                                <fi:SymbolIcon
                                                    FontSize="24"
                                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                    Symbol="Question" />
                                                <husk:PlaceholderContainer.SourceTemplate>
                                                    <DataTemplate x:DataType="x:Int32">
                                                        <TextBlock
                                                            FontSize="{StaticResource LargeFontSize}"
                                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                                            Text="{Binding}" />
                                                    </DataTemplate>
                                                </husk:PlaceholderContainer.SourceTemplate>
                                            </husk:PlaceholderContainer>
                                        </Border>
                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Text="{Binding Vendor, FallbackValue=Unknown}"
                                                TextTrimming="CharacterEllipsis" />
                                            <husk:Tag
                                                Classes="Small"
                                                IsVisible="{Binding Version, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                                Content="{Binding Version}" />
                                        </StackPanel>
                                        <husk:Tag
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Classes="Small"
                                            Content="{Binding Source}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{Binding Home}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </app:EmptyContainer>
                     <Button
                         Grid.Row="1"
                         Margin="0,8,0,0"
                         HorizontalAlignment="Right"
                         Classes="Small"
                         Command="{Binding $parent[app:RuntimePickerDialog].((app:RuntimePickerDialogModel)DataContext).RefreshCommand}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <fi:SymbolIcon FontSize="{StaticResource MediumFontSize}" Symbol="ArrowSync" />
                            <TextBlock Text="{x:Static lang:Resources.RuntimePickerDialog_RefreshButtonText}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </DataTemplate>
        </husk:PlaceholderContainer.SourceTemplate>
    </husk:PlaceholderContainer>
</husk:Dialog>
