<husk:Page
    x:Class="Polymerium.App.Pages.SnapshotCreationPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Header="创建快照"
    x:DataType="app:SnapshotCreationPageModel"
    mc:Ignorable="d">
    <Grid
        ColumnDefinitions="4*,6*"
        ColumnSpacing="12">
        <husk:PlaceholderContainer
            Grid.Column="1"
            Source="{Binding SnapshotTaken}"
            Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
            CornerRadius="{StaticResource MediumCornerRadius}">
            <husk:PlaceholderContainer.SourceTemplate>
                <DataTemplate DataType="app:SnapshotTakenModel">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="8" RowSpacing="8">
                        <Border Grid.Row="0" Background="{StaticResource ControlTranslucentHalfBackgroundBrush}" Padding="12,8">
                            <Border.CornerRadius>
                                <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                                    <Binding Path="CornerRadius" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=husk:PlaceholderContainer}"/>
                                    <Binding Path="Margin" RelativeSource="{RelativeSource FindAncestor, AncestorType=Grid}"/>
                                </MultiBinding>
                            </Border.CornerRadius>
                            <DockPanel>
                                <HyperlinkButton Classes="Danger" DockPanel.Dock="Right" Content="移除" />
                                <TextBlock Text="{Binding TakenAtRaw}" />
                            </DockPanel>
                        </Border>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Text="{Binding FileCount, Converter={x:Static app:HumanizerConverters.Metric}}"
                                    HorizontalAlignment="Center"
                                    FontSize="{StaticResource LargeFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}" />
                                <TextBlock Text="文件数" Foreground="{StaticResource  ControlSecondaryForegroundBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <husk:Divider Grid.Column="1" Orientation="Vertical" />
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Text="{Binding TotalSize, Converter={x:Static app:HumanizerConverters.ByteSize}}"
                                    HorizontalAlignment="Center"
                                    FontSize="{StaticResource LargeFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}" />
                                <TextBlock Text="总大小" Foreground="{StaticResource  ControlSecondaryForegroundBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="2" Background="{StaticResource OverlaySolidBackgroundBrush}" Padding="16">
                            <Border.CornerRadius>
                                <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                                    <Binding Path="CornerRadius" RelativeSource="{RelativeSource FindAncestor, AncestorType=husk:PlaceholderContainer}"/>
                                    <Binding Path="Margin" RelativeSource="{RelativeSource FindAncestor, AncestorType=Grid}"/>
                                </MultiBinding>
                            </Border.CornerRadius>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="游戏版本"
                                               Foreground="{StaticResource ControlSecondaryForegroundBrush}" />
                                    <TextBlock Text="{Binding VersionLabel}" FontSize="{StaticResource LargeFontSize}" />
                                    <TextBlock Text="加载器" Foreground="{StaticResource ControlSecondaryForegroundBrush}" />
                                    <TextBlock Text="{Binding LoaderLabel}" FontSize="{StaticResource LargeFontSize}" />
                                </StackPanel>
                                <DockPanel Grid.Column="1" VerticalSpacing="4">
                                    <TextBlock Text="包数量" DockPanel.Dock="Top"
                                               Foreground="{StaticResource ControlSecondaryForegroundBrush}" />
                                    <Border Background="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}"
                                            CornerRadius="{StaticResource MediumCornerRadius}">
                                        <TextBlock Text="{Binding PackageCount}" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource ControlAccentForegroundBrush}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource ExtraLargeFontSize}"
                                                   FontWeight="{StaticResource ControlStrongFontWeight}" />
                                    </Border>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </husk:PlaceholderContainer.SourceTemplate>
            <husk:SwitchContainer Value="{Binding IsSnapshotTaking}" TargetType="x:Boolean">
                <husk:SwitchCase Value="{x:False}">
                    <StackPanel VerticalAlignment="Center" Spacing="12">
                        <TextBlock FontSize="{StaticResource LargeFontSize}" Text="快照未拍摄"
                                   Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                   HorizontalAlignment="Center" />
                        <Button
                            Command="{Binding TakeCommand}"
                            Classes="Success"
                            HorizontalAlignment="Center">
                            <husk:IconLabel
                                Icon="Camera"
                                Text="拍摄" />
                        </Button>
                    </StackPanel>
                </husk:SwitchCase>
                <husk:SwitchCase Value="{x:True}">
                    <StackPanel>
                        <husk:ProgressRing Height="64" Width="64" HorizontalAlignment="Center" IsIndeterminate="True" />
                        <TextBlock Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                   HorizontalAlignment="Center">
                            <Run Text="{Binding TotalProcessed}" />
                            <Run Text="/" />
                            <Run Text="{Binding TotalCollected}" />
                        </TextBlock>
                    </StackPanel>
                </husk:SwitchCase>
            </husk:SwitchContainer>
        </husk:PlaceholderContainer>
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Bottom">
                <Button Classes="Primary">
                    <TextBlock Text="创建并插入数据库" />
                </Button>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="标签" />
                <TextBox PlaceholderText="用于提示快照的创建目的" />
                <TextBlock
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="备注" />
                <TextBox
                    MinHeight="128"
                    AcceptsReturn="True"
                    PlaceholderText="标签要是不够写这里还能再写点提示性的文字"
                    TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
    </Grid>
</husk:Page>
