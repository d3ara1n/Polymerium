<app:Subpage
    x:Class="Polymerium.App.Pages.InstanceWorkspacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstanceWorkspacePageModel"
    mc:Ignorable="d">
    <DockPanel VerticalSpacing="12">
        <!--  Status Bar  -->
        <Grid DockPanel.Dock="Top" />
        <!--  Nav Bar  -->
        <TabControl>
            <TabItem Header="Changes">
                <Grid ColumnDefinitions="*,Auto,*">
                    <ListBox
                        Grid.Column="0"
                        ItemsSource="{Binding Changes}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                <Grid
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto,Auto">
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <husk:SwitchPresenter
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        TargetType="app:WorkspaceChangeKind"
                                        Value="{Binding Kind}">
                                        <husk:SwitchCase Value="Same">
                                            <husk:Tag
                                                Classes="Small Success"
                                                Content="Same" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Outdated">
                                            <husk:Tag
                                                Classes="Small Warning"
                                                Content="Outdated" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Updated">
                                            <husk:Tag
                                                Classes="Small Warning"
                                                Content="Updated" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Deleted">
                                            <husk:Tag
                                                Classes="Small Danger"
                                                Content="Deleted" />
                                        </husk:SwitchCase>
                                    </husk:SwitchPresenter>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        FontSize="{StaticResource SmallFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{Binding RelativePath}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <GridSplitter Grid.Column="1" />
                    <Grid Grid.Column="2" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</app:Subpage>
