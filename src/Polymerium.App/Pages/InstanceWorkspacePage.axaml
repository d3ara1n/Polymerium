<app:Subpage
    x:Class="Polymerium.App.Pages.InstanceWorkspacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstanceWorkspacePageModel"
    mc:Ignorable="d">
    <DockPanel VerticalSpacing="12">
        <!--  Status Bar  -->
        <Grid DockPanel.Dock="Top" />
        <!--  Nav Bar  -->
        <TabControl>
            <TabItem Header="Changes">
                <Grid ColumnDefinitions="*,Auto,*">
                    <ListBox
                        Grid.Column="0"
                        ItemsSource="{Binding Changes}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="app:WorkspaceChangeModel" />
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <GridSplitter Grid.Column="1" />
                    <Grid Grid.Column="2" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</app:Subpage>
