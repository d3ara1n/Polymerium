<app:Subpage
    x:Class="Polymerium.App.Pages.InstanceWorkspacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstanceWorkspacePageModel"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <DockPanel VerticalSpacing="12">
        <!--  Status Bar  -->
        <Grid DockPanel.Dock="Top">
            <husk:InfoBar
                Classes="Warning"
                IsVisible="{Binding IsLocked}"
                Content="该实例导入自整合包，你将无法在整合包初始文件上应用修改。" />
        </Grid>
        <!--  Nav Bar  -->
        <TabControl>
            <TabItem Header="Changes">
                <Grid
                    ColumnDefinitions="*,4,*"
                    ColumnSpacing="12">
                    <DockPanel>
                        <ListBox
                            ItemsSource="{Binding Changes}"
                            SelectedItem="{Binding SelectedChange, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                    <Grid
                                        ColumnDefinitions="*,Auto"
                                        RowDefinitions="Auto,Auto">
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <husk:SwitchContainer
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            TargetType="app:WorkspaceChangeKind"
                                            Value="{Binding Kind}">
                                            <husk:SwitchCase Value="Same">
                                                <husk:Tag
                                                    Classes="Small Primary"
                                                    Content="无变化" />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Outdated">
                                                <husk:Tag
                                                    Classes="Small Warning"
                                                    Content="已过时"
                                                    ToolTip.Tip="该文件的初始版本发生变更，通常是由整合包更新引起。" />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Updated">
                                                <husk:Tag
                                                    Classes="Small Success"
                                                    Content="已更新"
                                                    ToolTip.Tip="该文件被客户端所修改。 " />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Deleted">
                                                <husk:Tag
                                                    Classes="Small Danger"
                                                    Content="已删除"
                                                    ToolTip.Tip="该文件的初始版本被移除，通常是由整合包更新引起。" />
                                            </husk:SwitchCase>
                                        </husk:SwitchContainer>
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            FontSize="{StaticResource SmallFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{Binding RelativePath}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                    <GridSplitter
                        Grid.Column="1"
                        ResizeDirection="Columns" />
                    <ScrollViewer Grid.Column="2">
                        <husk:PlaceholderContainer Source="{Binding SelectedChange}">
                            <husk:PlaceholderContainer.SourceTemplate>
                                <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                    <StackPanel Spacing="12">
                                        <husk:Card BorderThickness="0">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <husk:SwitchContainer
                                                    Grid.Column="0"
                                                    Width="4"
                                                    TargetType="app:WorkspaceChangeKind"
                                                    Value="{Binding Kind}">
                                                    <husk:SwitchCase Value="Updated">
                                                        <Border
                                                            Background="{StaticResource ControlSuccessBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Outdated">
                                                        <Border
                                                            Background="{StaticResource ControlWarningBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Deleted">
                                                        <Border
                                                            Background="{StaticResource ControlDangerBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Same">
                                                        <Border
                                                            Background="{StaticResource ControlAccentBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                </husk:SwitchContainer>
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    Spacing="8">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock
                                                            FontSize="{StaticResource ExtraLargeFontSize}"
                                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                                            Text="{Binding Name}"
                                                            TextWrapping="Wrap" />
                                                        <TextBlock
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="{Binding RelativePath}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <WrapPanel
                                                        ItemSpacing="6"
                                                        LineSpacing="6">
                                                        <husk:Tag Content="{Binding FileType, Converter={x:Static husk:StringConverters.ToUpper}}" />
                                                        <husk:SwitchContainer
                                                            TargetType="app:WorkspaceChangeKind"
                                                            Value="{Binding Kind}">
                                                            <husk:SwitchCase Value="Updated">
                                                                <husk:Tag
                                                                    Classes="Success"
                                                                    Content="已更新" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Outdated">
                                                                <husk:Tag
                                                                    Classes="Warning"
                                                                    Content="已过时" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Deleted">
                                                                <husk:Tag
                                                                    Classes="Danger"
                                                                    Content="已删除" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Same">
                                                                <husk:Tag
                                                                    Classes="Primary"
                                                                    Content="无变化" />
                                                            </husk:SwitchCase>
                                                        </husk:SwitchContainer>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </husk:Card>

                                        <husk:Card BorderThickness="0">
                                            <StackPanel Spacing="12">
                                                <TextBlock
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="快速信息" />
                                                <Grid
                                                    ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="16"
                                                    RowDefinitions="Auto,Auto,Auto"
                                                    RowSpacing="8">
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="类型" />
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Text="{Binding FileType}" />

                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="最后修改" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="1">
                                                        <Run Text="{Binding FileLastModifiedRaw, Mode=OneTime, Converter={x:Static app:HumanizerConverters.DateTime}}" />
                                                        <Run
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="•" />
                                                        <Run
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="{Binding FileLastModifiedRaw, StringFormat={}{0:g}}" />
                                                    </TextBlock>

                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="文件大小" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Text="{Binding FileSizeRaw, Mode=OneTime, Converter={x:Static app:HumanizerConverters.ByteSize}}" />
                                                </Grid>
                                            </StackPanel>
                                        </husk:Card>

                                        <husk:Card BorderThickness="0">
                                            <StackPanel Spacing="10">
                                                <TextBlock
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="建议操作" />
                                                <husk:SwitchContainer
                                                    TargetType="app:WorkspaceChangeKind"
                                                    Value="{Binding Kind}">
                                                    <husk:SwitchCase Value="Updated">
                                                        <Grid
                                                            ColumnDefinitions="*,*"
                                                            ColumnSpacing="10"
                                                            RowDefinitions="Auto,Auto"
                                                            RowSpacing="10">
                                                            <Button
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Grid.ColumnSpan="2"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="SplitVertical"
                                                                    Text="查看差异" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                Classes="Primary"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="应用" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).RestoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowImport"
                                                                    Text="放弃" />
                                                            </Button>
                                                        </Grid>
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Outdated">
                                                        <Grid
                                                            ColumnDefinitions="*,*"
                                                            ColumnSpacing="10"
                                                            RowDefinitions="Auto,Auto"
                                                            RowSpacing="10">
                                                            <Button
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Grid.ColumnSpan="2"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="SplitVertical"
                                                                    Text="查看差异" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                Classes="Primary"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="覆盖" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).RestoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowImport"
                                                                    Text="更新" />
                                                            </Button>
                                                        </Grid>
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Deleted">
                                                        <StackPanel Spacing="10">
                                                            <Button
                                                                Classes="Danger"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="删除" />
                                                            </Button>
                                                        </StackPanel>
                                                    </husk:SwitchCase>
                                                </husk:SwitchContainer>
                                                <husk:ButtonGroup>
                                                    <Button
                                                        Command="{x:Static app:InternalCommands.OpenFolderCommand}"
                                                        CommandParameter="{Binding LivePath}">
                                                        <husk:IconLabel
                                                            Icon="FolderOpen"
                                                            Text="打开位置" />
                                                    </Button>
                                                    <Button
                                                        Command="{x:Static app:InternalCommands.CopyToClipboardCommand}"
                                                        CommandParameter="{Binding RelativePath}">
                                                        <husk:IconLabel
                                                            Icon="DocumentCopy"
                                                            Text="复制路径" />
                                                    </Button>
                                                </husk:ButtonGroup>
                                            </StackPanel>
                                        </husk:Card>
                                    </StackPanel>
                                </DataTemplate>
                            </husk:PlaceholderContainer.SourceTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Text="选择一个文件" />
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="右侧会显示文件信息和可用操作。" />
                            </StackPanel>
                        </husk:PlaceholderContainer>
                    </ScrollViewer>

                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</app:Subpage>
