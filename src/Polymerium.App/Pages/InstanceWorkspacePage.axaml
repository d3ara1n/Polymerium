<app:Subpage
    x:Class="Polymerium.App.Pages.InstanceWorkspacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:fie="clr-namespace:FluentIcons.Avalonia.Markup;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstanceWorkspacePageModel"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <DockPanel VerticalSpacing="12">
        <!--  Status Bar  -->
        <StackPanel
            DockPanel.Dock="Top"
            Spacing="8">
            <!--  Git Bar  -->
            <Border
                Padding="12,8"
                IsVisible="{Binding IsGitRepository}"
                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <Grid
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="16">
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="12">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                Text="{x:Static lang:Resources.InstanceWorkspacePage_GitBarTitleText}" />
                            <TextBlock
                                FontSize="{StaticResource SmallFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.InstanceWorkspacePage_GitBarSubtitleText}" />
                        </StackPanel>
                        <husk:Divider Orientation="Vertical" />
                        <StackPanel
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Text="{x:Static lang:Resources.InstanceWorkspacePage_GitCommitSectionText}" />
                            <TextBlock
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{Binding GitHeadSummary}" />
                        </StackPanel>
                        <husk:Divider Orientation="Vertical" />
                        <StackPanel
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Text="{x:Static lang:Resources.InstanceWorkspacePage_GitWorkingTreeSectionText}" />
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock Foreground="{StaticResource ControlSuccessForegroundBrush}">
                                    <Run Text="{x:Static lang:Resources.InstanceWorkspacePage_GitStagedCountLabelText}" />
                                    <Run Text="{Binding GitStagedCount}" />
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource ControlDangerForegroundBrush}">
                                    <Run Text="{x:Static lang:Resources.InstanceWorkspacePage_GitUnstagedCountLabelText}" />
                                    <Run Text="{Binding GitUnstagedCount}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <husk:Divider Orientation="Vertical" />
                        <StackPanel
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Text="{x:Static lang:Resources.InstanceWorkspacePage_GitSyncSectionText}" />
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{Binding GitTrackingBranchName}" />
                                <TextBlock Foreground="{StaticResource ControlSuccessForegroundBrush}">
                                    <Run Text="↑" />
                                    <Run Text="{Binding GitAheadCount}" />
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource ControlDangerForegroundBrush}">
                                    <Run Text="↓" />
                                    <Run Text="{Binding GitBehindCount}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <SplitButton
                            Classes="Primary"
                            Command="{Binding CommitGitCommand}"
                            ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_GitCommitButtonToolTip}">
                            <husk:IconLabel
                                Icon="Checkmark"
                                Text="{x:Static lang:Resources.InstanceWorkspacePage_GitCommitButtonText}" />
                            <SplitButton.Flyout>
                                <MenuFlyout>
                                    <MenuItem
                                        Command="{Binding RestoreGitChangesCommand}"
                                        Header="{x:Static lang:Resources.InstanceWorkspacePage_GitRestoreMenuText}"
                                        Icon="{fie:SymbolIcon Symbol=ArrowReset,
                                                              FontSize={StaticResource MediumFontSize}}"
                                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_GitRestoreMenuToolTip}" />
                                </MenuFlyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                    </StackPanel>
                </Grid>
            </Border>
            <!--  Lock Info  -->
            <husk:InfoBar
                Classes="Warning"
                IsVisible="{Binding IsLocked}"
                Content="{x:Static lang:Resources.InstanceWorkspacePage_LockedInfoBarText}" />
        </StackPanel>
        <TabControl>
            <TabItem>
                <TabItem.Header>
                    <StackPanel
                        Background="Transparent"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_ChangesTabToolTip}">
                        <husk:IconLabel
                            Icon="DocumentLandscapeSplitHint"
                            Text="{x:Static lang:Resources.InstanceWorkspacePage_ChangesTabText}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid
                    ColumnDefinitions="*,4,*"
                    ColumnSpacing="12">
                    <DockPanel
                        Grid.Column="0"
                        VerticalSpacing="8">
                        <DockPanel
                            Dock="Top"
                            HorizontalSpacing="8">
                            <Button
                                DockPanel.Dock="Right"
                                Command="{Binding RefreshCommand}">
                                <husk:IconLabel
                                    Icon="ArrowCounterclockwise"
                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_RefreshButtonText}" />
                            </Button>
                            <TextBox
                                PlaceholderText="{x:Static lang:Resources.InstanceWorkspacePage_SearchPlaceholder}"
                                Text="{Binding FilterText, Mode=TwoWay}">
                                <TextBox.InnerRightContent>
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            IsVisible="{Binding $parent[TextBox].Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Command="{Binding $parent[TextBox].Clear}">
                                            <fi:SymbolIcon
                                                FontSize="{StaticResource SmallFontSize}"
                                                Symbol="Dismiss" />
                                        </Button>
                                        <TextBlock
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                                            <Run Text="{Binding ChangesView.Count, FallbackValue=0}" />
                                            <Run Text="/" />
                                            <Run Text="{Binding ChangesCount, FallbackValue=0}" />
                                        </TextBlock>
                                    </StackPanel>
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </DockPanel>
                        <app:EmptyContainer IsEmpty="{Binding ChangesView.Count, Converter={x:Static husk:NumberConverters.IsZero}}">
                            <ListBox
                                ItemsSource="{Binding ChangesView}"
                                SelectedItem="{Binding SelectedChange, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                        <Grid
                                            ColumnDefinitions="*,Auto"
                                            RowDefinitions="Auto,Auto">
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Text="{Binding FileName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <husk:SwitchContainer
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                TargetType="app:WorkspaceChangeKind"
                                                Value="{Binding Kind}">
                                                <husk:SwitchCase Value="Same">
                                                    <husk:Tag
                                                        Classes="Primary"
                                                        Content="{x:Static lang:Resources.InstanceWorkspacePage_SameTagText}" />
                                                </husk:SwitchCase>
                                                <husk:SwitchCase Value="Outdated">
                                                    <husk:Tag
                                                        Classes="Warning"
                                                        Content="{x:Static lang:Resources.InstanceWorkspacePage_OutdatedTagText}"
                                                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_OutdatedTagToolTip}" />
                                                </husk:SwitchCase>
                                                <husk:SwitchCase Value="Updated">
                                                    <husk:Tag
                                                        Classes="Success"
                                                        Content="{x:Static lang:Resources.InstanceWorkspacePage_UpdatedTagText}"
                                                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_UpdatedTagToolTip}" />
                                                </husk:SwitchCase>
                                                <husk:SwitchCase Value="Deleted">
                                                    <husk:Tag
                                                        Classes="Danger"
                                                        Content="{x:Static lang:Resources.InstanceWorkspacePage_DeletedTagText}"
                                                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_DeletedTagToolTip}" />
                                                </husk:SwitchCase>
                                            </husk:SwitchContainer>
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                FontSize="{StaticResource SmallFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{Binding RelativePath}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </app:EmptyContainer>
                    </DockPanel>
                    <GridSplitter
                        Grid.Column="1"
                        ResizeDirection="Columns" />
                    <ScrollViewer Grid.Column="2">
                        <husk:PlaceholderContainer Source="{Binding SelectedChange}">
                            <husk:PlaceholderContainer.SourceTemplate>
                                <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                    <StackPanel Spacing="12">
                                        <husk:Card BorderThickness="0">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <husk:SwitchContainer
                                                    Grid.Column="0"
                                                    Width="4"
                                                    TargetType="app:WorkspaceChangeKind"
                                                    Value="{Binding Kind}">
                                                    <husk:SwitchCase Value="Updated">
                                                        <Border
                                                            Background="{StaticResource ControlSuccessBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Outdated">
                                                        <Border
                                                            Background="{StaticResource ControlWarningBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Deleted">
                                                        <Border
                                                            Background="{StaticResource ControlDangerBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Same">
                                                        <Border
                                                            Background="{StaticResource ControlAccentBackgroundBrush}"
                                                            CornerRadius="2" />
                                                    </husk:SwitchCase>
                                                </husk:SwitchContainer>
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    Spacing="8">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock
                                                            FontSize="{StaticResource ExtraLargeFontSize}"
                                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                                            Text="{Binding FileName}"
                                                            TextWrapping="Wrap" />
                                                        <TextBlock
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="{Binding RelativePath}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <WrapPanel
                                                        ItemSpacing="6"
                                                        LineSpacing="6">
                                                        <husk:Tag Content="{Binding FileType, Converter={x:Static husk:StringConverters.ToUpper}}" />
                                                        <husk:SwitchContainer
                                                            TargetType="app:WorkspaceChangeKind"
                                                            Value="{Binding Kind}">
                                                            <husk:SwitchCase Value="Updated">
                                                                <husk:Tag
                                                                    Classes="Success"
                                                                    Content="{x:Static lang:Resources.InstanceWorkspacePage_UpdatedTagText}" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Outdated">
                                                                <husk:Tag
                                                                    Classes="Warning"
                                                                    Content="{x:Static lang:Resources.InstanceWorkspacePage_OutdatedTagText}" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Deleted">
                                                                <husk:Tag
                                                                    Classes="Danger"
                                                                    Content="{x:Static lang:Resources.InstanceWorkspacePage_DeletedTagText}" />
                                                            </husk:SwitchCase>
                                                            <husk:SwitchCase Value="Same">
                                                                <husk:Tag
                                                                    Classes="Primary"
                                                                    Content="{x:Static lang:Resources.InstanceWorkspacePage_SameTagText}" />
                                                            </husk:SwitchCase>
                                                        </husk:SwitchContainer>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </husk:Card>

                                        <husk:Card BorderThickness="0">
                                            <StackPanel Spacing="12">
                                                <TextBlock
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_QuickInfoTitle}" />
                                                <Grid
                                                    ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="16"
                                                    RowDefinitions="Auto,Auto,Auto"
                                                    RowSpacing="8">
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="{x:Static lang:Resources.InstanceWorkspacePage_FileTypeLabelText}" />
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Text="{Binding FileType}" />

                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="{x:Static lang:Resources.InstanceWorkspacePage_LastModifiedLabelText}" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="1">
                                                        <Run Text="{Binding FileLastModifiedRaw, Mode=OneTime, Converter={x:Static app:HumanizerConverters.DateTime}}" />
                                                        <Run
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="•" />
                                                        <Run
                                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                            Text="{Binding FileLastModifiedRaw, StringFormat={}{0:g}}" />
                                                    </TextBlock>

                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Text="{x:Static lang:Resources.InstanceWorkspacePage_FileSizeLabelText}" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Text="{Binding FileSizeRaw, Mode=OneTime, Converter={x:Static app:HumanizerConverters.ByteSize}}" />
                                                </Grid>
                                            </StackPanel>
                                        </husk:Card>

                                        <husk:Card BorderThickness="0">
                                            <StackPanel Spacing="10">
                                                <TextBlock
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_SuggestedActionsTitle}" />
                                                <husk:SwitchContainer
                                                    TargetType="app:WorkspaceChangeKind"
                                                    Value="{Binding Kind}">
                                                    <husk:SwitchCase Value="Updated">
                                                        <Grid
                                                            ColumnDefinitions="*,*"
                                                            ColumnSpacing="10"
                                                            RowDefinitions="Auto,Auto"
                                                            RowSpacing="10">
                                                            <Button
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Grid.ColumnSpan="2"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).OpenDifferCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="SplitVertical"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_ViewDiffButtonText}" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                Classes.Primary="{Binding !((app:InstanceWorkspacePageModel)DataContext).IsLocked, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:False}}"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_ApplyButtonText}" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Classes.Primary="{Binding ((app:InstanceWorkspacePageModel)DataContext).IsLocked, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:False}}"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).RestoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowImport"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_DiscardButtonText}" />
                                                            </Button>
                                                        </Grid>
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Outdated">
                                                        <Grid
                                                            ColumnDefinitions="*,*"
                                                            ColumnSpacing="10"
                                                            RowDefinitions="Auto,Auto"
                                                            RowSpacing="10">
                                                            <Button
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Grid.ColumnSpan="2"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).OpenDifferCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="SplitVertical"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_ViewDiffButtonText}" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                Classes.Primary="{Binding !((app:InstanceWorkspacePageModel)DataContext).IsLocked, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:False}}"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).StageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_OverwriteButtonText}" />
                                                            </Button>
                                                            <Button
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Classes.Primary="{Binding ((app:InstanceWorkspacePageModel)DataContext).IsLocked, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:False}}"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).RestoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowImport"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_UpdateButtonText}" />
                                                            </Button>
                                                        </Grid>
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Deleted">
                                                        <StackPanel Spacing="10">
                                                            <Button
                                                                Classes.Primary="{Binding !((app:InstanceWorkspacePageModel)DataContext).IsLocked, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:False}}"
                                                                Command="{Binding ((app:InstanceWorkspacePageModel)DataContext).RestoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type app:InstanceWorkspacePage}}, FallbackValue={x:Null}}"
                                                                CommandParameter="{Binding}">
                                                                <husk:IconLabel
                                                                    Icon="ArrowExport"
                                                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_DiscardButtonText}" />
                                                            </Button>
                                                        </StackPanel>
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Same" />
                                                </husk:SwitchContainer>
                                                <husk:ButtonGroup>
                                                    <Button
                                                        Command="{x:Static app:InternalCommands.OpenFolderCommand}"
                                                        CommandParameter="{Binding LivePath}">
                                                        <husk:IconLabel
                                                            Icon="FolderOpen"
                                                            Text="{x:Static lang:Resources.InstanceWorkspacePage_OpenLocationButtonText}" />
                                                    </Button>
                                                    <Button
                                                        Command="{x:Static app:InternalCommands.CopyToClipboardCommand}"
                                                        CommandParameter="{Binding RelativePath}">
                                                        <husk:IconLabel
                                                            Icon="DocumentCopy"
                                                            Text="{x:Static lang:Resources.InstanceWorkspacePage_CopyPathButtonText}" />
                                                    </Button>
                                                </husk:ButtonGroup>
                                            </StackPanel>
                                        </husk:Card>
                                    </StackPanel>
                                </DataTemplate>
                            </husk:PlaceholderContainer.SourceTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_SelectFileTitle}" />
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.InstanceWorkspacePage_SelectFilePrompt}" />
                            </StackPanel>
                        </husk:PlaceholderContainer>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel
                        Background="Transparent"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTip.Tip="{x:Static lang:Resources.InstanceWorkspacePage_FilesTabToolTip}">
                        <husk:IconLabel
                            Icon="FolderList"
                            Text="{x:Static lang:Resources.InstanceWorkspacePage_FilesTabText}" />
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
        </TabControl>
    </DockPanel>
</app:Subpage>
