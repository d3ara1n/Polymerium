<app:Subpage
    x:Class="Polymerium.App.Pages.InstanceWorkspacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstanceWorkspacePageModel"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <DockPanel VerticalSpacing="12">
        <!--  Status Bar  -->
        <Grid DockPanel.Dock="Top">
            <husk:InfoBar
                Classes="Warning"
                Content="该实例导入自整合包，你将无法在整合包初始文件上应用修改。" />
        </Grid>
        <!--  Nav Bar  -->
        <TabControl>
            <TabItem Header="Changes">
                <Grid ColumnDefinitions="*,Auto,*">
                    <DockPanel>
                        <ListBox
                            ItemsSource="{Binding Changes}"
                            SelectedItem="{Binding SelectedChange, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="app:WorkspaceChangeModel">
                                    <Grid
                                        ColumnDefinitions="*,Auto"
                                        RowDefinitions="Auto,Auto">
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <husk:SwitchPresenter
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            TargetType="app:WorkspaceChangeKind"
                                            Value="{Binding Kind}">
                                            <husk:SwitchCase Value="Same">
                                                <husk:Tag
                                                    Classes="Small Success"
                                                    Content="相同" />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Outdated">
                                                <husk:Tag
                                                    Classes="Small Warning"
                                                    Content="已过时"
                                                    ToolTip.Tip="该文件的初始版本发生变更，通常是由整合包更新引起。" />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Updated">
                                                <husk:Tag
                                                    Classes="Small Warning"
                                                    Content="已更新"
                                                    ToolTip.Tip="该文件被客户端所修改。 " />
                                            </husk:SwitchCase>
                                            <husk:SwitchCase Value="Deleted">
                                                <husk:Tag
                                                    Classes="Small Danger"
                                                    Content="已删除"
                                                    ToolTip.Tip="该文件的初始版本被移除，通常是由整合包更新引起。" />
                                            </husk:SwitchCase>
                                        </husk:SwitchPresenter>
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            FontSize="{StaticResource SmallFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{Binding RelativePath}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                    <GridSplitter Grid.Column="1" />
                    <Grid
                        Grid.Column="2"
                        RowDefinitions="Auto,*">
                        <husk:SwitchPresenter
                            Grid.Row="0"
                            Margin="4,2"
                            TargetType="app:WorkspaceChangeModel"
                            Value="{Binding SelectedChange?.Kind}">
                            <husk:SwitchCase Value="Outdated">
                                <husk:InfoBar Classes="Warning">
                                    <DockPanel>
                                        <StackPanel
                                            DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                            <Button Classes="Small Primary">
                                                <husk:IconLabel
                                                    Icon="ArrowExport"
                                                    Text="覆盖" />
                                            </Button>
                                            <Button Classes="Small">
                                                <husk:IconLabel
                                                    Icon="ArrowImport"
                                                    Text="更新" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="这份文件内容落后于原始版本。" />
                                    </DockPanel>
                                </husk:InfoBar>
                            </husk:SwitchCase>
                            <husk:SwitchCase Value="Updated">
                                <husk:InfoBar Classes="Success">
                                    <DockPanel>
                                        <StackPanel
                                            DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                            <Button Classes="Small Primary">
                                                <husk:IconLabel
                                                    Icon="ArrowExport"
                                                    Text="应用" />
                                            </Button>
                                            <Button Classes="Small">
                                                <husk:IconLabel
                                                    Icon="ArrowImport"
                                                    Text="放弃" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="这份文件自原始版本后被更新。" />
                                    </DockPanel>
                                </husk:InfoBar>
                            </husk:SwitchCase>
                            <husk:SwitchCase Value="Deleted">
                                <husk:InfoBar Classes="Danger">
                                    <DockPanel>
                                        <StackPanel
                                            DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                            <Button Classes="Small Primary">
                                                <husk:IconLabel
                                                    Icon="ArrowExport"
                                                    Text="覆盖" />
                                            </Button>
                                            <Button Classes="Small">
                                                <husk:IconLabel
                                                    Icon="ArrowImport"
                                                    Text="更新" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="这份文件的原始版本已被移除。" />
                                    </DockPanel>
                                </husk:InfoBar>
                            </husk:SwitchCase>
                        </husk:SwitchPresenter>
                    </Grid>

                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</app:Subpage>
