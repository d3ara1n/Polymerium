<app:Subpage
    x:Class="Polymerium.App.Pages.InstancePropertiesPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="using:FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:InstancePropertiesPageModel"
    mc:Ignorable="d">
    <StackPanel
        MaxWidth="1440"
        Margin="24"
        Spacing="12">
        <app:SettingsEntry
            Title="{x:Static lang:Resources.InstancePropertiesPage_TitleTitle}"
            Icon="AppTitle"
            Summary="{x:Static lang:Resources.InstancePropertiesPage_TitleSubtitle}">
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_DisplayNameLabelText}">
                <Border
                    Background="{StaticResource ControlBackgroundBrush}"
                    CornerRadius="{StaticResource MediumCornerRadius}">
                    <StackPanel
                        Margin="3"
                        Spacing="3">
                        <Border Background="{StaticResource OverlaySolidBackgroundBrush}">
                            <Border.CornerRadius>
                                <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                    <StaticResource ResourceKey="SmallCornerRadius" />
                                    <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                </MultiBinding>
                            </Border.CornerRadius>
                            <TextBlock
                                Margin="8"
                                FontSize="{StaticResource LargeFontSize}"
                                Text="{Binding NameOverwrite, FallbackValue=Name}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </Border>
                        <Button
                            Classes="Small"
                            Command="{Binding RenameInstanceCommand}"
                            Content="{x:Static lang:Resources.InstancePropertiesPage_RenameButtonText}"
                            Theme="{StaticResource OutlineButtonTheme}">
                            <Button.CornerRadius>
                                <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                    <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                    <StaticResource ResourceKey="SmallCornerRadius" />
                                </MultiBinding>
                            </Button.CornerRadius>
                        </Button>
                    </StackPanel>
                </Border>
            </app:SettingsEntryItem>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_ThumbnailLabelText}">
                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                    <Border
                        Grid.Column="0"
                        Width="72"
                        Height="72"
                        Padding="8"
                        HorizontalAlignment="Center"
                        Background="{StaticResource LayerBackgroundBrush}"
                        BorderBrush="{x:Null}"
                        CornerRadius="{StaticResource SmallCornerRadius}">
                        <Border.Effect>
                            <DropShadowEffect Opacity="0.1" />
                        </Border.Effect>
                        <Border
                            Name="ThumbnailBox"
                            CornerRadius="{StaticResource SmallCornerRadius}">
                            <Border.Background>
                                <ImageBrush Source="{Binding ThumbnailOverwrite}" />
                            </Border.Background>
                        </Border>

                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="12">
                        <Button
                            Classes="Small"
                            Command="{Binding SelectThumbnailCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="4">
                                <fi:SymbolIcon
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource SmallFontSize}"
                                    Symbol="Document" />
                                <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_SelectButtonText}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Classes="Small"
                            Command="{Binding RemoveThumbnailCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="4">
                                <fi:SymbolIcon
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource SmallFontSize}"
                                    Symbol="Delete" />
                                <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_RemoveButtonText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </app:SettingsEntryItem>
        </app:SettingsEntry>
        <husk:Divider />
        <app:SettingsEntry
            Title="{x:Static lang:Resources.InstancePropertiesPage_OverridesTitle}"
            Icon="Games"
            Summary="{x:Static lang:Resources.InstancePropertiesPage_OverridesSubtitle}">
            <Button Command="{Binding GotoSettingsCommand}">
                <Grid ColumnDefinitions="Auto,8,*">
                    <fi:SymbolIcon
                        Grid.Column="0"
                        Symbol="DocumentOnePage" />
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center">
                        <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_NavigateToGlobalButtonTitle}" />
                        <TextBlock
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.InstancePropertiesPage_NavigateToGlobalButtonSubtitle}" />
                    </StackPanel>
                </Grid>
            </Button>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_JavaHomeLabelText}">
                <TextBox
                    PlaceholderText="{Binding JavaHomeWatermark}"
                    Text="{Binding JavaHomeOverride, Mode=TwoWay, FallbackValue={x:Null}}">
                    <TextBox.InnerRightContent>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding $parent[TextBox].Clear}">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource SmallFontSize}"
                                    Symbol="Dismiss" />
                            </Button>
                            <Button
                                Command="{Binding PickFileCommand}"
                                CommandParameter="{Binding $parent[TextBox]}">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="DocumentArrowLeft" />
                            </Button>
                        </StackPanel>
                    </TextBox.InnerRightContent>
                </TextBox>
            </app:SettingsEntryItem>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_JavaMaxMemoryLabelText}">
                <NumericUpDown
                    Increment="512"
                    Minimum="0"
                    PlaceholderText="{Binding JavaMaxMemoryWatermark}"
                    Value="{Binding JavaMaxMemoryOverride, Mode=TwoWay}">
                    <NumericUpDown.InnerRightContent>
                        <StackPanel Orientation="Horizontal">
                            <husk:Divider Orientation="Vertical" />
                            <TextBlock
                                Margin="8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.InstancePropertiesPage_JavaMaxMemoryUnitText}" />
                        </StackPanel>
                    </NumericUpDown.InnerRightContent>
                </NumericUpDown>
            </app:SettingsEntryItem>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_JavaAdditionalArgumentsLabelText}">
                <TextBox
                    PlaceholderText="{Binding JavaAdditionalArgumentsWatermark}"
                    Text="{Binding JavaAdditionalArgumentsOverride, Mode=TwoWay}" />
            </app:SettingsEntryItem>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_WindowInitialSizeLabelText}">
                <Grid ColumnDefinitions="*,7,*">
                    <TextBox
                        Grid.Column="0"
                        PlaceholderText="{Binding WindowInitialWidthWatermark}"
                        Text="{Binding WindowInitialWidthOverride, Mode=TwoWay}">
                        <TextBox.InnerLeftContent>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.InstancePropertiesPage_WindowWidthLabelText}" />
                                <husk:Divider Orientation="Vertical" />
                            </StackPanel>
                        </TextBox.InnerLeftContent>
                    </TextBox>
                    <TextBox
                        Grid.Column="2"
                        PlaceholderText="{Binding WindowInitialHeightWatermark}"
                        Text="{Binding WindowInitialHeightOverride, Mode=TwoWay}">
                        <TextBox.InnerLeftContent>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.InstancePropertiesPage_WindowHeightLabelText}" />
                                <husk:Divider Orientation="Vertical" />
                            </StackPanel>
                        </TextBox.InnerLeftContent>
                    </TextBox>
                </Grid>
            </app:SettingsEntryItem>
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_QuickConnectLabelText}">
                <TextBox
                    PlaceholderText="{Binding QuickConnectAddressWatermark}"
                    Text="{Binding QuickConnectAddressOverride, Mode=TwoWay}" />
            </app:SettingsEntryItem>
        </app:SettingsEntry>
        <husk:Divider />
        <!-- <app:SettingsEntry Icon="Camera" Title="Snapshots (WIP)" Summary="Backup, yes, it's called backup"> -->
        <!--     <app:SettingsEntryItem Header="Taken Automatically When"> -->
        <!--         <ComboBox SelectedIndex="0"> -->
        <!--             <ComboBoxItem Content="Never" /> -->
        <!--             <ComboBoxItem Content="Built" /> -->
        <!--         </ComboBox> -->
        <!--     </app:SettingsEntryItem> -->
        <!--     <app:SettingsEntryItem Header="Folders"> -->
        <!--         <TextBox PlaceholderText="Replace this with a TokenTextBox!!!" /> -->
        <!--     </app:SettingsEntryItem> -->
        <!--     <app:SettingsEntryItem Header="Files"> -->
        <!--         <TextBox PlaceholderText="Replace this with a TokenTextBox!!!" /> -->
        <!--     </app:SettingsEntryItem> -->
        <!-- </app:SettingsEntry> -->
        <!-- <husk:Divider /> -->
        <app:SettingsEntry
            Title="{x:Static lang:Resources.InstancePropertiesPage_BehaviorsTitle}"
            Icon="Handshake"
            Summary="{x:Static lang:Resources.InstancePropertiesPage_BehaviorsSubtitle}">
            <!-- <app:SettingsEntryItem Header="[Experimental] Deployment Method"> -->
            <!--     <StackPanel Spacing="8"> -->
            <!--         <ComboBox SelectedIndex="0" IsEnabled="False"> -->
            <!--             <ComboBoxItem Content="Auto" /> -->
            <!--         </ComboBox> -->
            <!--     </StackPanel> -->
            <!-- </app:SettingsEntryItem> -->
            <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_FastLaunchLabelText}">
                <StackPanel Spacing="8">
                    <husk:InfoBar Content="{x:Static lang:Resources.InstancePropertiesPage_FastLaunchPrompt}" />
                    <ToggleSwitch
                        IsChecked="{Binding BehaviorDeployFastMode, Mode=TwoWay}"
                        OffContent="{x:Static lang:Resources.Enum_Off}"
                        OnContent="{x:Static lang:Resources.InstancePropertiesPage_FastLaunchOnText}" />
                </StackPanel>
            </app:SettingsEntryItem>
        </app:SettingsEntry>
        <husk:Divider />
        <husk:BusyContainer
            Background="Transparent"
            IsBusy="{Binding State, Converter={x:Static husk:ObjectConverters.NotMatch}, ConverterParameter=Idle, FallbackValue=False}">
            <app:SettingsEntry
                Title="{x:Static lang:Resources.InstancePropertiesPage_DebugTitle}"
                Icon="Bug"
                Summary="{x:Static lang:Resources.InstancePropertiesPage_DebugSubtitle}">
                <app:SettingsEntryItem Header="{x:Static lang:Resources.InstancePropertiesPage_CheckIntegrityLabelText}">
                    <Button Command="{Binding CheckIntegrityCommand}">
                        <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_CheckIntegrityButtonText}" />
                    </Button>
                </app:SettingsEntryItem>
            </app:SettingsEntry>
            <husk:BusyContainer.PendingContent>
                <husk:Card
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlaySolidBackgroundBrush}">
                    <StackPanel Spacing="12">
                        <fi:SymbolIcon
                            Height="{StaticResource ExtraLargeFontSize}"
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource ExtraLargeFontSize}"
                            Symbol="Info" />
                        <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_InoperableLabelText}" />
                    </StackPanel>
                </husk:Card>
            </husk:BusyContainer.PendingContent>
        </husk:BusyContainer>
        <husk:Divider>
            <StackPanel
                Orientation="Horizontal"
                Spacing="8">
                <fi:SymbolIcon
                    FontSize="{StaticResource MediumFontSize}"
                    Symbol="Warning" />
                <TextBlock Text="猫脑过载" />
                <fi:SymbolIcon
                    FontSize="{StaticResource MediumFontSize}"
                    Symbol="Warning" />
            </StackPanel>
        </husk:Divider>
        <husk:BusyContainer
            Background="Transparent"
            IsBusy="{Binding State, Converter={x:Static husk:ObjectConverters.NotMatch}, ConverterParameter=Idle, FallbackValue=False}">
            <app:SettingsEntry
                Title="{x:Static lang:Resources.InstancePropertiesPage_DangerZoneTitle}"
                Icon="WarningShield"
                Summary="{x:Static lang:Resources.InstancePropertiesPage_DangerZoneSubtitle}">
                <app:SafeLock
                    Name="Lock"
                    SafeCode="{Binding SafeCode}" />
                <app:SettingsEntryItem
                    IsEnabled="{Binding #Lock.IsUnlocked}"
                    Header="{x:Static lang:Resources.InstancePropertiesPage_SacrificeLabelText}">
                    <Grid ColumnDefinitions="*,8,*">
                        <Button
                            Grid.Column="0"
                            Command="{Binding ResetInstanceCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="ArrowReset" />
                                <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_ResetButtonText}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="2"
                            Classes="Danger"
                            Command="{Binding DeleteInstanceCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="Delete" />
                                <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_DeleteButtonText}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </app:SettingsEntryItem>
                <app:SettingsEntryItem
                    IsEnabled="{Binding #Lock.IsUnlocked}"
                    IsVisible="{Binding Basic.Source, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Header="{x:Static lang:Resources.InstancePropertiesPage_LinkerLabelText}">
                    <StackPanel Spacing="8">
                        <husk:InfoBar Content="{x:Static lang:Resources.InstancePropertiesPage_LinkerPrompt}" />
                        <Button Command="{Binding UnlockInstanceCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="WarningLockOpen" />
                                <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_UnlockButtonText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </app:SettingsEntryItem>
            </app:SettingsEntry>
            <husk:BusyContainer.PendingContent>
                <husk:Card
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlaySolidBackgroundBrush}">
                    <StackPanel Spacing="12">
                        <fi:SymbolIcon
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource ExtraLargeFontSize}"
                            Symbol="Info" />
                        <TextBlock Text="{x:Static lang:Resources.InstancePropertiesPage_InoperableLabelText}" />
                    </StackPanel>
                </husk:Card>
            </husk:BusyContainer.PendingContent>
        </husk:BusyContainer>
    </StackPanel>
</app:Subpage>
