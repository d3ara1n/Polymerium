<husk:Page
    x:Class="Polymerium.App.Pages.SnapshotManagementPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="using:FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Header="{x:Static lang:Resources.SnapshotManagementPage_Title}"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*,Auto,*">
        <ListBox
            x:Name="SnapshotList"
            Grid.Column="0"
            SelectionChanged="OnSnapshotSelectionChanged">
            <ListBoxItem>
                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                    <fi:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="DocumentBulletList" />
                    <StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <TextBlock
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="Initial Setup" />
                        <TextBlock
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="2025-03-15 10:30" />
                    </StackPanel>
                </Grid>
            </ListBoxItem>
            <ListBoxItem>
                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                    <fi:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="DocumentBulletList" />
                    <StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <TextBlock
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="Before Mod Update" />
                        <TextBlock
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="2025-03-18 14:22" />
                    </StackPanel>
                </Grid>
            </ListBoxItem>
            <ListBoxItem>
                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                    <fi:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="DocumentBulletList" />
                    <StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <TextBlock
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="Pre-Cleanup Backup" />
                        <TextBlock
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="2025-03-20 09:45" />
                    </StackPanel>
                </Grid>
            </ListBoxItem>
        </ListBox>
        <GridSplitter
            Grid.Column="1"
            ResizeDirection="Columns" />
        <Panel Grid.Column="2">
            <StackPanel
                x:Name="DetailPanel"
                Margin="24"
                IsVisible="False"
                Spacing="16">
                <TextBlock
                    x:Name="DetailTitle"
                    FontSize="{StaticResource ExtraLargeFontSize}"
                    FontWeight="{StaticResource ControlStrongFontWeight}" />

                <husk:Divider />

                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="16"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="12">
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_LabelLabelText}" />
                    <TextBlock
                        x:Name="DetailLabel"
                        Grid.Row="0"
                        Grid.Column="1"
                        FontWeight="{StaticResource ControlStrongFontWeight}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_RemarkLabelText}" />
                    <TextBlock
                        x:Name="DetailRemark"
                        Grid.Row="1"
                        Grid.Column="1" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_CreatedAtLabelText}" />
                    <TextBlock
                        x:Name="DetailCreatedAt"
                        Grid.Row="2"
                        Grid.Column="1" />

                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_GameVersionLabelText}" />
                    <TextBlock
                        x:Name="DetailVersion"
                        Grid.Row="3"
                        Grid.Column="1" />

                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_LoaderLabelText}" />
                    <TextBlock
                        x:Name="DetailLoader"
                        Grid.Row="4"
                        Grid.Column="1" />

                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_PackageCountLabelText}" />
                    <TextBlock
                        x:Name="DetailPackageCount"
                        Grid.Row="5"
                        Grid.Column="1" />

                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="0"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_TotalSizeLabelText}" />
                    <TextBlock
                        x:Name="DetailTotalSize"
                        Grid.Row="6"
                        Grid.Column="1" />
                </Grid>
            </StackPanel>

            <TextBlock
                x:Name="DetailEmptyHint"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{x:Static lang:Resources.SnapshotManagementPage_DetailSelectHintText}" />
        </Panel>
    </Grid>
</husk:Page>
