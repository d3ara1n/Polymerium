<UserControl
    x:Class="Polymerium.App.Components.JavaHomeContainer"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Padding="3"
        Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
        CornerRadius="{StaticResource MediumCornerRadius}">
        <husk:SwitchContainer
            TargetType="x:Boolean"
            Value="{Binding $parent[app:JavaHomeContainer].Home, Converter={x:Static ObjectConverters.IsNotNull}}">
            <husk:SwitchCase Value="{x:True}">
                <Grid
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="3">
                    <Border
                        Grid.Column="0"
                        Padding="12,8"
                        Background="{StaticResource OverlaySolidBackgroundBrush}"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        ToolTip.Tip="{Binding $parent[app:JavaHomeContainer].Home}">
                        <Grid
                            ColumnDefinitions="Auto,Auto,*"
                            ColumnSpacing="12">
                            <husk:PlaceholderContainer
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Source="{Binding $parent[app:JavaHomeContainer].Major}">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource ExtraLargeFontSize}"
                                    Symbol="Question" />
                                <husk:PlaceholderContainer.SourceTemplate>
                                    <DataTemplate x:DataType="x:Int32">
                                        <TextBlock
                                            FontSize="{StaticResource ExtraLargeFontSize}"
                                            Text="{Binding}" />
                                    </DataTemplate>
                                </husk:PlaceholderContainer.SourceTemplate>
                            </husk:PlaceholderContainer>
                            <husk:Divider
                                Grid.Column="1"
                                Orientation="Vertical" />
                            <Grid
                                Grid.Column="2"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="8"
                                RowDefinitions="*,*">
                                <husk:PlaceholderContainer
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Source="{Binding $parent[app:JavaHomeContainer].Vendor}">
                                    <TextBlock Text="{x:Static lang:Resources.JavaHomeContainer_UnknownLabelText}" />
                                    <husk:PlaceholderContainer.SourceTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{Binding}" />
                                        </DataTemplate>
                                    </husk:PlaceholderContainer.SourceTemplate>
                                </husk:PlaceholderContainer>
                                <husk:Tag
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Classes="Small"
                                    IsVisible="{Binding $parent[app:JavaHomeContainer].Version, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                    Content="{Binding $parent[app:JavaHomeContainer].Version}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{Binding $parent[app:JavaHomeContainer].Home}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>
                    </Border>
                    <Button
                        Grid.Column="1"
                        Padding="6"
                        Command="{Binding $parent[app:JavaHomeContainer].RemoveCommand}"
                        Theme="{StaticResource GhostButtonTheme}">
                        <fi:SymbolIcon
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Symbol="Dismiss" />
                    </Button>
                </Grid>
            </husk:SwitchCase>
            <husk:SwitchCase Value="{x:False}">
                <StackPanel
                    Margin="12"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <fi:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Symbol="HexagonSparkle" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.JavaHomeContainer_Prompt}" />
                    <Button
                        Classes="Small"
                        IsEnabled="False"
                        Background="{StaticResource ControlTranslucentHalfBackgroundBrush}"
                        Command="{Binding $parent[app:JavaHomeContainer].DetectHomeCommand}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <fi:SymbolIcon
                                FontSize="{StaticResource MediumFontSize}"
                                Symbol="FolderSearch" />
                            <TextBlock Text="{x:Static lang:Resources.JavaHomeContainer_DetectButtonText}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Classes="Small"
                        Background="{StaticResource ControlTranslucentHalfBackgroundBrush}"
                        Command="{Binding $parent[app:JavaHomeContainer].PickFileCommand}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <fi:SymbolIcon
                                FontSize="{StaticResource MediumFontSize}"
                                Symbol="DocumentSearch" />
                            <TextBlock Text="{x:Static lang:Resources.JavaHomeContainer_BrowseButtonText}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </husk:SwitchCase>
        </husk:SwitchContainer>
    </Border>
</UserControl>
