<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">

    <x:Double x:Key="DiffLineHeight">22</x:Double>
    <x:Double x:Key="DiffFontSize">13</x:Double>

    <ControlTheme
        x:Key="{x:Type app:DiffView}"
        TargetType="app:DiffView">
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource SmallCornerRadius}">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{TemplateBinding Lines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="app:DiffLineModel">
                                    <Grid MinHeight="{StaticResource DiffLineHeight}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition MinWidth="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition MinWidth="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            BorderBrush="{StaticResource ControlBorderBrush}"
                                            BorderThickness="0,0,1,0">
                                            <TextBlock
                                                Margin="8,2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                                FontSize="{StaticResource DiffFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{Binding LeftLineNumber}" />
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Background="{Binding LeftKind, Converter={x:Static app:InternalConverters.DiffLineKindToBackground}}">
                                            <TextBlock
                                                Margin="8,2"
                                                VerticalAlignment="Center"
                                                FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                                FontSize="{StaticResource DiffFontSize}"
                                                Text="{Binding LeftText}" />
                                        </Border>
                                        <Border
                                            Grid.Column="2"
                                            Background="{StaticResource ControlBorderBrush}" />
                                        <Border
                                            Grid.Column="3"
                                            BorderBrush="{StaticResource ControlBorderBrush}"
                                            BorderThickness="0,0,1,0">
                                            <TextBlock
                                                Margin="8,2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                                FontSize="{StaticResource DiffFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{Binding RightLineNumber}" />
                                        </Border>
                                        <Border
                                            Grid.Column="4"
                                            Background="{Binding RightKind, Converter={x:Static app:InternalConverters.DiffLineKindToBackground}}">
                                            <TextBlock
                                                Margin="8,2"
                                                VerticalAlignment="Center"
                                                FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                                FontSize="{StaticResource DiffFontSize}"
                                                Text="{Binding RightText}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
