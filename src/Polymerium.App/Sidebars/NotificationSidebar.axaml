<husk:Sidebar
    x:Class="Polymerium.App.Sidebars.NotificationSidebar"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:async="using:AsyncImageLoader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="using:FluentIcons.Avalonia"
    xmlns:fie="using:FluentIcons.Avalonia.Markup"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="380"
    Padding="0"
    d:DesignHeight="600"
    d:DesignWidth="400"
    x:DataType="{x:Type app:MainWindowContext}"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*">
        <Grid
            Grid.Row="0"
            Margin="{StaticResource SidebarBottomlessContentMargin}"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="{StaticResource LargeFontSize}"
                FontWeight="{StaticResource ControlStrongFontWeight}"
                Text="{x:Static lang:Resources.NotificationSidebar_NotificationsLabelText}" />
            <Button
                Grid.Column="1"
                Classes="Small"
                IsEnabled="{Binding UnreadNotificationCount, Converter={x:Static husk:NumberConverters.IsNonZero}}"
                Command="{Binding MarkAllAsReadCommand}"
                Theme="{StaticResource OutlineButtonTheme}">
                <husk:IconLabel
                    Icon="Checkmark"
                    Text="{x:Static lang:Resources.NotificationSidebar_MarkAllAsReadButtonText}" />
            </Button>
            <Button
                Grid.Column="2"
                Classes="Small"
                Click="DismissButton_OnClick">
                <fi:SymbolIcon
                    FontSize="{StaticResource MediumFontSize}"
                    Symbol="Dismiss" />
            </Button>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel
                Margin="{StaticResource SidebarContentMargin}"
                HorizontalAlignment="Center"
                IsVisible="{Binding Notifications.Count, Converter={x:Static husk:NumberConverters.IsZero}}"
                Spacing="8">
                <Border
                    Width="56"
                    Height="56"
                    Background="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}"
                    CornerRadius="28">
                    <fi:SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="AlertOff" />
                </Border>
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource MediumFontSize}"
                    FontWeight="{StaticResource ControlStrongFontWeight}"
                    Text="{x:Static lang:Resources.NotificationSidebar_EmptyTitle}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="{x:Static lang:Resources.NotificationSidebar_EmptyPrompt}" />
            </StackPanel>
            <ScrollViewer IsVisible="{Binding Notifications.Count, Converter={x:Static husk:NumberConverters.IsNonZero}}">
                <ItemsControl
                    Margin="{StaticResource SidebarContentMargin}"
                    ItemsSource="{Binding Notifications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="app:NotificationModel">
                            <Border
                                Margin="4,4,4,4"
                                BoxShadow="0 0 4 0 #3F000000"
                                CornerRadius="{StaticResource LargeCornerRadius}">
                                <Panel>
                                    <husk:SwitchPresenter
                                        TargetType="husk:GrowlLevel"
                                        Value="{Binding Level}">
                                        <husk:SwitchCase Value="Information">
                                            <Border
                                                Padding="12,10"
                                                Background="{StaticResource OverlaySolidBackgroundBrush}"
                                                BorderBrush="{StaticResource ControlBorderBrush}"
                                                BorderThickness="3,0,0,0"
                                                CornerRadius="{Binding $parent[Border].CornerRadius}" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Success">
                                            <Border
                                                Padding="12,10"
                                                Background="{StaticResource OverlaySolidBackgroundBrush}"
                                                BorderBrush="{StaticResource ControlSuccessBorderBrush}"
                                                BorderThickness="3,0,0,0"
                                                CornerRadius="{Binding $parent[Border].CornerRadius}" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Warning">
                                            <Border
                                                Padding="12,10"
                                                Background="{StaticResource OverlaySolidBackgroundBrush}"
                                                BorderBrush="{StaticResource ControlWarningBorderBrush}"
                                                BorderThickness="3,0,0,0"
                                                CornerRadius="{Binding $parent[Border].CornerRadius}" />
                                        </husk:SwitchCase>
                                        <husk:SwitchCase Value="Danger">
                                            <Border
                                                Padding="12,10"
                                                Background="{StaticResource OverlaySolidBackgroundBrush}"
                                                BorderBrush="{StaticResource ControlDangerBorderBrush}"
                                                BorderThickness="3,0,0,0"
                                                CornerRadius="{Binding $parent[Border].CornerRadius}" />
                                        </husk:SwitchCase>
                                    </husk:SwitchPresenter>
                                    <DockPanel Margin="12,8">
                                        <StackPanel
                                            DockPanel.Dock="Bottom"
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Right"
                                            IsVisible="{Binding Actions.Count, Converter={x:Static husk:NumberConverters.IsNonZero}}"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <ItemsControl
                                                IsEnabled="{Binding IsCancelled, Converter={x:Static BoolConverters.Not}}"
                                                ItemsSource="{Binding Actions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel
                                                            ItemSpacing="8"
                                                            LineSpacing="8" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="husk:GrowlAction">
                                                        <Button
                                                            Classes="Small"
                                                            Command="{Binding Command}"
                                                            CommandParameter="{Binding Parameter}"
                                                            Content="{Binding Text}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <Grid
                                            ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                            RowDefinitions="Auto,*"
                                            RowSpacing="4">
                                            <Panel
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Grid.Column="0">
                                                <husk:SwitchPresenter
                                                    Width="28"
                                                    Height="28"
                                                    Margin="4"
                                                    TargetType="husk:GrowlLevel"
                                                    Value="{Binding Level}">
                                                    <husk:SwitchCase Value="Information">
                                                        <Ellipse Fill="{StaticResource ControlTranslucentFullBackgroundBrush}" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Success">
                                                        <Ellipse Fill="{StaticResource ControlSuccessTranslucentFullBackgroundBrush}" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Warning">
                                                        <Ellipse Fill="{StaticResource ControlWarningTranslucentFullBackgroundBrush}" />
                                                    </husk:SwitchCase>
                                                    <husk:SwitchCase Value="Danger">
                                                        <Ellipse Fill="{StaticResource ControlDangerTranslucentFullBackgroundBrush}" />
                                                    </husk:SwitchCase>
                                                </husk:SwitchPresenter>
                                                <Ellipse
                                                    Width="28"
                                                    Height="28"
                                                    Margin="4">
                                                    <Ellipse.Fill>
                                                        <ImageBrush async:ImageBrushLoader.Source="{Binding Thumbnail}" />
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <husk:ProgressRing
                                                    Width="32"
                                                    Height="32"
                                                    IsVisible="{Binding IsProgressBarVisible}"
                                                    IsIndeterminate="{Binding IsProgressIndeterminate}"
                                                    ShowProgressText="False"
                                                    StrokeWidth="4"
                                                    TrackStrokeWidth="4"
                                                    Value="{Binding Progress}" />
                                            </Panel>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Orientation="Horizontal">
                                                <husk:Tag
                                                    Classes="Small Primary"
                                                    Margin="8,0,0,0"
                                                    IsVisible="{Binding IsRead, Converter={x:Static BoolConverters.Not}}"
                                                    Content="{x:Static lang:Resources.NotificationSidebar_UnreadTagText}" />
                                                <husk:Tag
                                                    Classes="Small"
                                                    Margin="8,0,0,0"
                                                    IsVisible="{Binding IsCancelled}"
                                                    Content="{x:Static lang:Resources.NotificationSidebar_CancelledTagText}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Text="{Binding Title}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="3"
                                                Margin="8,0,0,0"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{Binding PublishedAt}" />
                                            <Button
                                                Grid.Row="0"
                                                Grid.Column="4"
                                                Classes="Small"
                                                Margin="8,0,0,0"
                                                Padding="8,2"
                                                CornerRadius="{StaticResource SmallCornerRadius}">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem
                                                            IsVisible="{Binding IsRead, Converter={x:Static BoolConverters.Not}}"
                                                            Command="{Binding $parent[app:NotificationSidebar].((app:MainWindowContext)DataContext).MarkAsReadCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding}"
                                                            Header="{x:Static lang:Resources.NotificationSidebar_MarkAsReadMenuText}"
                                                            Icon="{fie:SymbolIcon CheckmarkCircle,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem
                                                            IsVisible="{Binding IsRead}"
                                                            Command="{Binding $parent[app:NotificationSidebar].((app:MainWindowContext)DataContext).MarkAsUnreadCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding}"
                                                            Header="{x:Static lang:Resources.NotificationSidebar_MarkAsUnreadMenuText}"
                                                            Icon="{fie:SymbolIcon CheckmarkCircleHint,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:NotificationSidebar].((app:MainWindowContext)DataContext).RemoveNotificationCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding}"
                                                            Header="{x:Static lang:Resources.NotificationSidebar_RemoveMenuText}"
                                                            Icon="{fie:SymbolIcon DismissCircle,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                                <fi:SymbolIcon
                                                    FontSize="{StaticResource SmallFontSize}"
                                                    Symbol="MoreHorizontal" />
                                            </Button>
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Grid.ColumnSpan="4"
                                                Margin="8,0,0,0"
                                                Text="{Binding Message}"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                    </DockPanel>
                                </Panel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</husk:Sidebar>
