<husk:Page
    x:Class="Polymerium.Avalonia.Pages.SnapshotManagementPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="using:FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:SnapshotManagementPageModel"
    Header="{x:Static lang:Resources.SnapshotManagementPage_Title}"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="4*,Auto,6*">
        <DockPanel Grid.Column="0">
            <Grid
                DockPanel.Dock="Top"
                Margin="0,0,0,8"
                ColumnDefinitions="*,Auto">
                <TextBox
                    Grid.Column="0"
                    PlaceholderText="{x:Static lang:Resources.SnapshotManagementPage_SearchPlaceholder}"
                    Text="{Binding SearchText, Mode=TwoWay}">
                    <TextBox.InnerRightContent>
                        <Button
                            IsVisible="{Binding $parent[TextBox].Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Command="{Binding $parent[TextBox].Clear}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                            <fi:SymbolIcon
                                FontSize="{StaticResource MediumFontSize}"
                                Symbol="Dismiss" />
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>
            </Grid>

            <Panel>
                <ListBox
                    x:Name="SnapshotList"
                    ItemsSource="{Binding Snapshots}"
                    SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="app:SnapshotItemModel">
                            <Grid
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="12">
                                <fi:SymbolIcon
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="{StaticResource ControlAccentForegroundBrush}"
                                    Symbol="DocumentBulletList" />
                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="2">
                                    <TextBlock
                                        FontWeight="{StaticResource ControlStrongFontWeight}"
                                        Text="{Binding DisplayLabel}" />
                                    <TextBlock
                                        FontSize="{StaticResource SmallFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{Binding CreatedAtText}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsVisible="{Binding Snapshots.Count, Converter={x:Static husk:NumberConverters.IsZero}}"
                    Spacing="8">
                    <fi:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="32"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Symbol="DocumentBulletListOff" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.SnapshotManagementPage_EmptyListLabelText}" />
                </StackPanel>
            </Panel>
        </DockPanel>

        <GridSplitter
            Grid.Column="1"
            Margin="12,0"
            ResizeDirection="Columns" />


        <husk:PlaceholderContainer
            Grid.Column="2"
            Source="{Binding Detail}">
            <husk:PlaceholderContainer.SourceTemplate>
                <DataTemplate DataType="app:SnapshotDetailModel">
                    <ScrollViewer>
                        <StackPanel
                            Margin="8"
                            Spacing="12">
                            <!--  Header  -->
                            <StackPanel Spacing="4">
                                <TextBlock
                                    FontSize="{StaticResource LargeFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Text="{Binding Label}" />
                                <TextBlock
                                    FontSize="{StaticResource SmallFontSize}"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{Binding CreatedAtText}" />
                            </StackPanel>

                            <!--  Remark  -->
                            <Border
                                Padding="12"
                                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                                CornerRadius="{StaticResource MediumCornerRadius}">
                                <TextBlock
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{Binding Remark}"
                                    TextWrapping="Wrap" />
                            </Border>

                            <!--  Stats cards  -->
                            <Grid
                                ColumnDefinitions="*,*,*"
                                ColumnSpacing="8">
                                <Border
                                    Grid.Column="0"
                                    Padding="12,8"
                                    Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                                    CornerRadius="{StaticResource MediumCornerRadius}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource LargeFontSize}"
                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                            Text="{Binding PackageCount, Converter={x:Static app:HumanizerConverters.Metric}}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource CaptionFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{x:Static lang:Resources.SnapshotManagementPage_PackageCountLabelText}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    Padding="12,8"
                                    Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                                    CornerRadius="{StaticResource MediumCornerRadius}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource LargeFontSize}"
                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                            Text="{Binding FileCount, Converter={x:Static app:HumanizerConverters.Metric}}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource CaptionFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{x:Static lang:Resources.SnapshotManagementPage_FileCountLabelText}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="2"
                                    Padding="12,8"
                                    Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                                    CornerRadius="{StaticResource MediumCornerRadius}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource LargeFontSize}"
                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                            Text="{Binding TotalSizeFormatted}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource CaptionFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            Text="{x:Static lang:Resources.SnapshotManagementPage_TotalSizeLabelText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!--  Diff section (only shown when there's a previous snapshot)  -->
                            <Border
                                Padding="12"
                                IsVisible="{Binding Diff, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
                                CornerRadius="{StaticResource MediumCornerRadius}">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontSize="{StaticResource SmallFontSize}"
                                        FontWeight="{StaticResource ControlStrongFontWeight}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{x:Static lang:Resources.SnapshotManagementPage_DiffSectionLabelText}" />
                                    <Grid
                                        ColumnDefinitions="*,*"
                                        ColumnSpacing="8"
                                        RowDefinitions="Auto,Auto"
                                        RowSpacing="4">
                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Spacing="2">
                                            <TextBlock
                                                FontSize="{StaticResource CaptionFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{x:Static lang:Resources.SnapshotManagementPage_FilesAddedLabelText}" />
                                            <TextBlock
                                                FontSize="{StaticResource MediumFontSize}"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Foreground="{StaticResource ControlSuccessForegroundBrush}"
                                                Text="{Binding Diff?.FilesAdded}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Spacing="2">
                                            <TextBlock
                                                FontSize="{StaticResource CaptionFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{x:Static lang:Resources.SnapshotManagementPage_FilesRemovedLabelText}" />
                                            <TextBlock
                                                FontSize="{StaticResource MediumFontSize}"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Foreground="{StaticResource ControlDangerForegroundBrush}"
                                                Text="{Binding Diff?.FilesRemoved}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Spacing="2">
                                            <TextBlock
                                                FontSize="{StaticResource CaptionFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{x:Static lang:Resources.SnapshotManagementPage_PackagesAddedLabelText}" />
                                            <TextBlock
                                                FontSize="{StaticResource MediumFontSize}"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Foreground="{StaticResource ControlSuccessForegroundBrush}"
                                                Text="{Binding Diff?.PackagesAdded}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Spacing="2">
                                            <TextBlock
                                                FontSize="{StaticResource CaptionFontSize}"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="{x:Static lang:Resources.SnapshotManagementPage_PackagesRemovedLabelText}" />
                                            <TextBlock
                                                FontSize="{StaticResource MediumFontSize}"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Foreground="{StaticResource ControlDangerForegroundBrush}"
                                                Text="{Binding Diff?.PackagesRemoved}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <husk:Divider />

                            <!--  Game info  -->
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="{StaticResource SmallFontSize}"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.SnapshotManagementPage_ConfigInfoLabelText}" />
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="8"
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="4">
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{x:Static lang:Resources.SnapshotManagementPage_GameVersionLabelText}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Text="{Binding GameVersion}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{x:Static lang:Resources.SnapshotManagementPage_LoaderLabelText}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding Loader}" />
                                </Grid>
                            </StackPanel>

                            <!--  Actions  -->
                            <husk:Divider />
                            <Grid
                                ColumnDefinitions="*,*"
                                ColumnSpacing="8">
                                <Button
                                    Grid.Column="0"
                                    Classes="Primary"
                                    Command="{Binding $parent[app:SnapshotManagementPage].((app:SnapshotManagementPageModel)DataContext).RestoreCommand}">
                                    <husk:IconLabel
                                        Icon="ArrowReset"
                                        Text="{x:Static lang:Resources.SnapshotManagementPage_RestoreButtonText}" />
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    Classes="Danger"
                                    Command="{Binding $parent[app:SnapshotManagementPage].((app:SnapshotManagementPageModel)DataContext).DeleteCommand}">
                                    <husk:IconLabel
                                        Icon="Delete"
                                        Text="{x:Static lang:Resources.SnapshotManagementPage_DeleteButtonText}" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>
            </husk:PlaceholderContainer.SourceTemplate>

            <!--  Empty state: no snapshot selected  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <fi:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="32"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Symbol="DocumentBulletListOff" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="{x:Static lang:Resources.SnapshotManagementPage_SelectToViewLabelText}" />
            </StackPanel>
        </husk:PlaceholderContainer>
    </Grid>
</husk:Page>
