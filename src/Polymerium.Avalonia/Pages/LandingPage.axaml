<husk:Page
    x:Class="Polymerium.Avalonia.Pages.LandingPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:async="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:collections="clr-namespace:System.Collections;assembly=System.Runtime"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Padding="{StaticResource PageHeaderlessContentMargin}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    x:DataType="app:LandingPageModel"
    Background="Transparent"
    IsHeaderVisible="False"
    mc:Ignorable="d">
    <StackPanel Spacing="24">

        <!--  Header Section  -->
        <Grid
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="12">
            <Image
                Grid.Column="0"
                Width="48"
                Height="48"
                Opacity="0.9"
                RenderOptions.BitmapInterpolationMode="HighQuality"
                Source="/Assets/Icon.png" />
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="{StaticResource ExtraLargeFontSize}"
                    FontWeight="{StaticResource ControlStrongFontWeight}"
                    Text="{x:Static app:Program.Brand}">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Offset="0" Color="{DynamicResource Accent8Color}" />
                            <GradientStop Offset="1" Color="{DynamicResource Accent11Color}" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Foreground="{StaticResource ControlSecondaryForegroundBrush}">
                    <Run Text="{Binding Source={x:Static app:Program.Version}, StringFormat={}v{0}}" />
                    <Run Text="·" />
                    <Run Text="{x:Static app:Program.ReleaseDate}" />
                </TextBlock>
            </StackPanel>
            <Grid
                Grid.Column="2"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <husk:Card
                    Grid.Column="0"
                    Padding="12,8">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12"
                        RowDefinitions="*,Auto">
                        <fi:SymbolIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="{StaticResource ExtraLargeFontSize}"
                            Foreground="{StaticResource ControlAccentForegroundBrush}"
                            Symbol="CubeMultiple" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontSize="{StaticResource LargeFontSize}"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding InstanceCount, FallbackValue=12}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.LandingPage_OverviewInstancesLabelText}" />
                    </Grid>
                </husk:Card>
                <husk:Card
                    Grid.Column="1"
                    Padding="12,8">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12"
                        RowDefinitions="*,Auto">
                        <fi:SymbolIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="{StaticResource ExtraLargeFontSize}"
                            Foreground="{StaticResource ControlAccentForegroundBrush}"
                            Symbol="People" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontSize="{StaticResource LargeFontSize}"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding AccountCount, FallbackValue=1}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.LandingPage_OverviewAccountsLabelText}" />
                    </Grid>
                </husk:Card>
            </Grid>
        </Grid>

        <!--  Announcements  -->
        <Panel IsVisible="False" />

        <!--  Content Area  -->
        <Grid
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12"
            RowDefinitions="Auto,Auto"
            RowSpacing="12">

            <!--  Continue Play  -->
            <husk:PlaceholderContainer
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                ClipToBounds="False"
                Source="{Binding RecentPlay}">
                <husk:PlaceholderContainer.SourceTemplate>
                    <DataTemplate DataType="app:RecentPlayModel">
                        <!--  CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource FindAncestor, AncestorType=husk:Card}, Converter={x:Static husk:CornerRadiusConverters.ToInnerRadius}, ConverterParameter=8}"  -->
                        <Border
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource MediumCornerRadius}">
                            <DockPanel>
                                <Border
                                    DockPanel.Dock="Top"
                                    Background="{StaticResource OverlaySolidBackgroundBrush}"
                                    BoxShadow="0 0 4 0 #1F000000"
                                    CornerRadius="{husk:StaticResourceBinding MediumCornerRadius,
                                                                              Converter={x:Static husk:CornerRadiusConverters.Top}}">
                                    <Grid
                                        Margin="{StaticResource CardContentMargin}"
                                        ColumnDefinitions="*,Auto">
                                        <Grid
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            ColumnDefinitions="Auto,*"
                                            ColumnSpacing="12">
                                            <Border
                                                Grid.Column="0"
                                                Width="{Binding $self.Bounds.Height}"
                                                CornerRadius="{StaticResource SmallCornerRadius}">
                                                <Border.Background>
                                                    <ImageBrush Source="{Binding Thumbnail}" />
                                                </Border.Background>
                                            </Border>
                                            <StackPanel
                                                Grid.Column="1"
                                                Spacing="2">
                                                <TextBlock
                                                    FontSize="{StaticResource LargeFontSize}"
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    FontSize="{StaticResource SmallFontSize}"
                                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                    Text="{Binding LastPlayed}" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Classes="Primary"
                                                Padding="12,8"
                                                Command="{Binding $parent[app:LandingPage].((app:LandingPageModel)DataContext).PlayCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding Key}">
                                                <husk:IconLabel
                                                    Icon="Play"
                                                    Text="{x:Static lang:Resources.LandingPage_RecentPlayButtonText}" />
                                            </Button>
                                            <Button
                                                Classes="Small"
                                                Command="{Binding $parent[app:LandingPage].((app:LandingPageModel)DataContext).ViewInstanceCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding Key}">
                                                <fi:SymbolIcon
                                                    FontSize="{StaticResource SmallFontSize}"
                                                    Symbol="ChevronRight" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Panel>
                                    <Border CornerRadius="{Binding CornerRadius, Converter={x:Static husk:CornerRadiusConverters.Bottom}, RelativeSource={RelativeSource FindAncestor, AncestorType=Border}}">
                                        <Border.Background>
                                            <ImageBrush
                                                Source="{Binding Screenshot}"
                                                Stretch="UniformToFill" />
                                        </Border.Background>
                                        <Border.OpacityMask>
                                            <LinearGradientBrush StartPoint="0%,90%" EndPoint="100%,0%">
                                                <GradientStop Offset="0" Color="#3F000000" />
                                                <GradientStop Offset="0.5" Color="#6F000000" />
                                                <GradientStop Offset="1" Color="#DF000000" />
                                            </LinearGradientBrush>
                                        </Border.OpacityMask>
                                    </Border>
                                    <Border Padding="{StaticResource CardContentMargin}">
                                        <husk:Card
                                            Padding="18"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource OverlaySolidBackgroundBrush}"
                                            BorderThickness="0"
                                            BoxShadow="0 0 4 0 #3F000000">
                                            <!--  Left: Mod badge + Stats  -->
                                            <StackPanel Spacing="12">
                                                <!--  Mod count badge + Version info  -->
                                                <StackPanel Spacing="6">
                                                    <Grid
                                                        ColumnDefinitions="Auto,*"
                                                        ColumnSpacing="10">
                                                        <!--  Big accent number  -->
                                                        <Border
                                                            Grid.Column="0"
                                                            Padding="8,0"
                                                            Background="{StaticResource ControlAccentBackgroundBrush}"
                                                            CornerRadius="{StaticResource MediumCornerRadius}">
                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="{StaticResource ExtraLargeFontSize}"
                                                                FontWeight="Bold"
                                                                Foreground="{StaticResource ControlWhiteForegroundBrush}"
                                                                Text="{Binding PackageCount}" />
                                                        </Border>
                                                        <StackPanel
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="4">
                                                            <TextBlock
                                                                FontSize="{StaticResource MediumFontSize}"
                                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                                Text="{x:Static lang:Resources.LandingPage_RecentPlayPackagesText}" />
                                                            <StackPanel
                                                                Orientation="Horizontal"
                                                                Spacing="6">
                                                                <husk:Tag Content="{Binding Version}" />
                                                                <husk:Tag Content="{Binding LoaderLabel}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                                <!--  Detail stats  -->
                                                <StackPanel
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <husk:Card
                                                        Padding="10,8"
                                                        BorderThickness="0">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock
                                                                FontSize="{StaticResource SmallFontSize}"
                                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                                Text="{x:Static lang:Resources.LandingPage_RecentPlayPlayTimeText}" />
                                                            <TextBlock
                                                                FontSize="{StaticResource MediumFontSize}"
                                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                                Text="{Binding LastPlayTime}" />
                                                        </StackPanel>
                                                    </husk:Card>
                                                    <husk:Card
                                                        Padding="10,8"
                                                        BorderThickness="0">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock
                                                                FontSize="{StaticResource SmallFontSize}"
                                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                                Text="{x:Static lang:Resources.LandingPage_RecentPlaySessionsText}" />
                                                            <TextBlock
                                                                FontSize="{StaticResource MediumFontSize}"
                                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                                Text="{Binding SessionCount}" />
                                                        </StackPanel>
                                                    </husk:Card>
                                                </StackPanel>
                                            </StackPanel>
                                        </husk:Card>
                                    </Border>
                                </Panel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </husk:PlaceholderContainer.SourceTemplate>
                <husk:PlaceholderContainer.Placeholder>
                    <husk:Card CornerRadius="{StaticResource MediumCornerRadius}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                            <fi:SymbolIcon
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource ExtraLargeFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Symbol="Games" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource LargeFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.LandingPage_NoRecentPlayLabelText}" />
                        </StackPanel>
                    </husk:Card>
                </husk:PlaceholderContainer.Placeholder>
            </husk:PlaceholderContainer>

            <!--  Random Play  -->
            <husk:Card
                Grid.Row="0"
                Grid.Column="1">
                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12"
                    RowDefinitions="*,Auto"
                    RowSpacing="12">
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="24"
                        Text="🤔" />
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1">
                        <TextBlock
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{x:Static lang:Resources.LandingPage_RandomPlayTitle}" />
                        <TextBlock
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.LandingPage_RandomPlaySubtitle}" />
                    </StackPanel>
                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Classes="Small"
                        Command="{Binding TryOneCommand}"
                        Theme="{StaticResource OutlineButtonTheme}">
                        <husk:IconLabel
                            Icon="HandWave"
                            Text="{x:Static lang:Resources.LandingPage_RandomPlayButtonText}" />
                    </Button>
                </Grid>
            </husk:Card>

            <!--  Statistics  -->
            <husk:Card
                Grid.Row="1"
                Grid.Column="1">
                <StackPanel Spacing="8">
                    <!--  Total Play Time  -->
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.LandingPage_StatisticsHoursLabelText}" />
                        <TextBlock
                            FontSize="{StaticResource ExtraLargeFontSize}"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding TotalPlayHours, StringFormat={}{0:0.0} hrs, FallbackValue=45.3 hrs}" />
                    </StackPanel>

                    <husk:Divider
                        Height="1"
                        Orientation="Horizontal" />

                    <!--  Sessions  -->
                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="12">
                        <StackPanel
                            Grid.Column="0"
                            Spacing="4">
                            <TextBlock
                                FontSize="{StaticResource MediumFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.LandingPage_StatisticsSessionsLabelText}" />
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                Text="{Binding TotalSessions, FallbackValue=12}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Spacing="4">
                            <TextBlock
                                FontSize="{StaticResource MediumFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.LandingPage_StatisticsActiveDaysLabelText}" />
                            <TextBlock
                                FontSize="{StaticResource LargeFontSize}"
                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                Text="{Binding ActiveDays, FallbackValue=6}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </husk:Card>
        </Grid>

        <!--  Quick Actions  -->
        <!-- <WrapPanel ItemSpacing="6" LineSpacing="6" ItemHeight="128" ItemWidth="168"> -->
        <!--     <husk:Card Padding="0"> -->
        <!--         <Grid RowDefinitions="*,Auto,Auto"> -->
        <!--  <TextBlock Grid.Row="0" Text="I have a hat."  -->
        <!--  Margin="{StaticResource CardContentMargin}" />  -->
        <!--             <husk:Divider Grid.Row="1" /> -->
        <!--             <StackPanel Grid.Row="2" Margin="3"> -->
        <!--                 <StackPanel.Styles> -->
        <!--                     <Style Selector="Button"> -->
        <!--                         <Setter Property="Theme" Value="{StaticResource GhostButtonTheme}" /> -->
        <!--                         <Setter Property="Padding" Value="8,4" /> -->
        <!--                         <Setter Property="FontSize" Value="{StaticResource SmallFontSize}" /> -->
        <!--                         <Setter Property="CornerRadius"> -->
        <!--  <MultiBinding  -->
        <!--  Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">  -->
        <!--  <Binding Path="CornerRadius"  -->
        <!--  RelativeSource="{RelativeSource FindAncestor, AncestorType=husk:Card}" />  -->
        <!--  <Binding Path="Margin"  -->
        <!--  RelativeSource="{RelativeSource FindAncestor, AncestorType=StackPanel}" />  -->
        <!--                             </MultiBinding> -->
        <!--                         </Setter> -->
        <!--                     </Style> -->
        <!--                 </StackPanel.Styles> -->
        <!--                 <Button> -->
        <!--                     <husk:IconLabel Icon="HandLeft" Text="Steal" /> -->
        <!--                 </Button> -->
        <!--             </StackPanel> -->
        <!--         </Grid> -->
        <!--     </husk:Card> -->
        <!-- </WrapPanel> -->

        <!--  News Section  -->
        <DockPanel
            MinHeight="24"
            VerticalSpacing="8">
            <TextBlock
                DockPanel.Dock="Top"
                FontSize="{StaticResource LargeFontSize}"
                FontWeight="{StaticResource ControlStrongFontWeight}"
                Text="{x:Static lang:Resources.LandingPage_RecentReleasesLabelText}" />
            <husk:LazyContainer
                MinHeight="220"
                Source="{Binding MinecraftNews}">
                <husk:LazyContainer.SourceTemplate>
                    <DataTemplate DataType="collections:IList">
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <app:WaterfallPanel ColumnWidth="262" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="app:MinecraftReleasePatchModel">
                                    <husk:Card>
                                        <Grid
                                            RowDefinitions="Auto,*"
                                            RowSpacing="12">
                                            <husk:ConstrainedBox
                                                Grid.Row="0"
                                                AspectRatio="117:50">
                                                <Border CornerRadius="{StaticResource MediumCornerRadius}">
                                                    <Border.Background>
                                                        <ImageBrush
                                                            async:ImageBrushLoader.Source="{Binding Cover}"
                                                            Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                            </husk:ConstrainedBox>
                                            <StackPanel
                                                Grid.Row="1"
                                                Spacing="4">
                                                <TextBlock
                                                    FontSize="{StaticResource LargeFontSize}"
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="{Binding Title}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />
                                                <DockPanel HorizontalSpacing="8">
                                                    <husk:Tag
                                                        DockPanel.Dock="Right"
                                                        Classes="Small">
                                                        <TextBlock Text="{Binding Category}" />
                                                    </husk:Tag>
                                                    <husk:IconLabel
                                                        FontSize="{StaticResource SmallFontSize}"
                                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                        Icon="Clock"
                                                        Text="{Binding PublishedAt}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </husk:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </husk:LazyContainer.SourceTemplate>
                <husk:LazyContainer.FaultContent>
                    <husk:Card MinHeight="220">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{x:Static lang:Resources.LandingPage_MinecraftNewsErrorText}" />
                            <Button
                                Classes="Small"
                                HorizontalAlignment="Center"
                                Command="{Binding $parent[app:LandingPage].((app:LandingPageModel)DataContext).RefreshMinecraftNewsCommand}"
                                Theme="{StaticResource OutlineButtonTheme}">
                                <husk:IconLabel
                                    Icon="ArrowClockwise"
                                    Text="{x:Static lang:Resources.LandingPage_RetryButtonText}" />
                            </Button>
                        </StackPanel>
                    </husk:Card>
                </husk:LazyContainer.FaultContent>
            </husk:LazyContainer>
        </DockPanel>
    </StackPanel>
</husk:Page>
