<app:ScopedPage
    x:Class="Polymerium.Avalonia.Pages.InstancePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="using:FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Padding="0"
    d:DesignHeight="600"
    d:DesignWidth="700"
    x:DataType="app:InstancePageModel"
    Context="{Binding Context, Mode=OneWay}"
    IsHeaderVisible="False"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <Panel>
        <husk:DropContainer
            DragOver="DropContainer_OnDragOver"
            Drop="DropContainer_OnDrop">
            <husk:DropContainer.Overlay>
                <Panel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Rectangle
                        Fill="{StaticResource ControlInteractiveBackgroundBrush}"
                        RadiusX="6"
                        RadiusY="6"
                        Stroke="{StaticResource ControlInteractiveBorderBrush}"
                        StrokeDashArray="6,2"
                        StrokeJoin="Round"
                        StrokeLineCap="Round"
                        StrokeThickness="2" />
                    <StackPanel
                        Margin="48,36"
                        Opacity="{StaticResource Overlay1Opacity}"
                        Spacing="12">
                        <fi:SymbolIcon
                            Height="42"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource ControlWhiteForegroundBrush}"
                            Symbol="DocumentAdd" />
                    </StackPanel>
                </Panel>
            </husk:DropContainer.Overlay>
            <Grid ColumnDefinitions="Auto,*">
                <Border
                    Grid.Column="0"
                    Width="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}, Converter={x:Static app:InternalConverters.SidebarExpandedToWidth}}"
                    Margin="12,12,0,12"
                    Background="{StaticResource LayerBackgroundBrush}"
                    CornerRadius="{StaticResource MediumCornerRadius}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition
                                Easing="CubicEaseOut"
                                Property="Width"
                                Duration="{StaticResource ControlFasterAnimationDuration}" />
                        </Transitions>
                    </Border.Transitions>
                    <Grid
                        RowDefinitions="Auto,*,Auto,Auto"
                        RowSpacing="12">
                        <StackPanel
                            Grid.Row="0"
                            Margin="12"
                            Spacing="2">
                            <Button Command="{Binding $parent[husk:Frame].GoBackCommand}">
                                <Button.CornerRadius>
                                    <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                        <StaticResource ResourceKey="MediumCornerRadius" />
                                        <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                    </MultiBinding>
                                </Button.CornerRadius>
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="ArrowLeft" />
                            </Button>
                            <Button
                                HorizontalContentAlignment="Center"
                                Command="{Binding ToggleSidebarCommand}">
                                <Button.CornerRadius>
                                    <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                        <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                        <StaticResource ResourceKey="MediumCornerRadius" />
                                    </MultiBinding>
                                </Button.CornerRadius>
                                <Panel>
                                    <fi:SymbolIcon
                                        IsVisible="{Binding !ViewState?.IsSidebarExpanded, FallbackValue={x:True}}"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="PanelLeftExpand" />
                                    <fi:SymbolIcon
                                        IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="PanelLeftContract" />
                                </Panel>
                            </Button>
                        </StackPanel>
                        <ListBox
                            x:Name="EntryBox"
                            Grid.Row="1"
                            Padding="0"
                            ClipToBounds="False"
                            ItemsSource="{Binding PageEntries}"
                            SelectedValue="{Binding SelectedPage}"
                            SelectionChanged="EntryBox_OnSelectionChanged"
                            SelectionMode="Single">
                            <ListBox.ItemContainerTheme>
                                <ControlTheme TargetType="ListBoxItem">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="ClipToBounds" Value="False" />
                                    <Setter Property="Template">
                                        <ControlTemplate>
                                            <Panel
                                                Background="{StaticResource TransparentBrush}"
                                                ToolTip.HorizontalOffset="5"
                                                ToolTip.Placement="Right"
                                                ToolTip.Tip="{Binding Label, RelativeSource={RelativeSource Mode=DataContext}, x:DataType=app:InstanceSubpageEntryModel}"
                                                ToolTip.VerticalOffset="0">
                                                <Border
                                                    Name="Indicator"
                                                    Background="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}"
                                                    Opacity="0">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition
                                                                Easing="CubicEaseOut"
                                                                Property="Opacity"
                                                                Duration="{StaticResource ControlFasterAnimationDuration}" />
                                                        </Transitions>
                                                    </Border.Transitions>
                                                </Border>
                                                <Border
                                                    Name="Lock"
                                                    BorderBrush="{StaticResource ControlAccentInteractiveBorderBrush}"
                                                    BorderThickness="3,0"
                                                    Opacity="0"
                                                    RenderTransform="scaleX(1.1)">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition
                                                                Property="Opacity"
                                                                Duration="{StaticResource ControlFasterAnimationDuration}" />
                                                            <TransformOperationsTransition
                                                                Easing="CubicEaseOut"
                                                                Property="RenderTransform"
                                                                Duration="{StaticResource ControlFasterAnimationDuration}" />
                                                        </Transitions>
                                                    </Border.Transitions>
                                                </Border>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <fi:SymbolIcon
                                                        Grid.Column="0"
                                                        Margin="24,8,0,8"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource MediumFontSize}"
                                                        Symbol="{Binding Icon, RelativeSource={RelativeSource Mode=DataContext}, x:DataType=app:InstanceSubpageEntryModel}">
                                                        <fi:SymbolIcon.Transitions>
                                                            <Transitions>
                                                                <BrushTransition
                                                                    Property="Foreground"
                                                                    Duration="{StaticResource ControlFasterAnimationDuration}" />
                                                            </Transitions>
                                                        </fi:SymbolIcon.Transitions>
                                                    </fi:SymbolIcon>
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="10,0,12,0"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding $parent[app:InstancePage].((app:InstancePageModel)DataContext).ViewState.IsSidebarExpanded, FallbackValue={x:False}}"
                                                        Text="{Binding Label, RelativeSource={RelativeSource Mode=DataContext}, x:DataType=app:InstanceSubpageEntryModel}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Panel>
                                        </ControlTemplate>
                                    </Setter>
                                    <Style Selector="^:pointerover /template/ Border#Indicator">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                    <Style Selector="^:selected /template/ Border#Indicator">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                    <Style Selector="^:selected /template/ Border#Lock">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="RenderTransform" Value="scaleX(1.0)" />
                                    </Style>
                                    <Style Selector="^:selected /template/ fi|SymbolIcon">
                                        <Setter Property="Foreground" Value="{StaticResource ControlAccentForegroundBrush}" />
                                        <Setter Property="IconVariant" Value="Filled" />
                                    </Style>
                                </ControlTheme>
                            </ListBox.ItemContainerTheme>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                        <StackPanel
                            Grid.Row="2"
                            Margin="12,0"
                            Spacing="2">
                            <Button
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding ImportFromFileCommand}"
                                ToolTip.Tip="{x:Static lang:Resources.InstancePage_ImportAssetToolTipText}">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding
                                            Converter="{x:Static husk:ObjectConverters.NotMatch}"
                                            ConverterParameter="Updating"
                                            Path="State" />
                                        <Binding
                                            Converter="{x:Static husk:ObjectConverters.NotMatch}"
                                            ConverterParameter="Deploying"
                                            Path="State" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                                <Button.CornerRadius>
                                    <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                        <StaticResource ResourceKey="MediumCornerRadius" />
                                        <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                    </MultiBinding>
                                </Button.CornerRadius>
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="12">
                                    <fi:SymbolIcon
                                        Grid.Column="0"
                                        Height="{StaticResource MediumFontSize}"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="DocumentAdd" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                        FontSize="{StaticResource SmallFontSize}"
                                        Text="{x:Static lang:Resources.InstancePage_ImportAssetLabelText}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding ExportInstanceCommand}"
                                CornerRadius="{StaticResource ExtraSmallCornerRadius}"
                                ToolTip.Tip="{x:Static lang:Resources.InstancePage_ExportModpackToolTipText}">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding
                                            Converter="{x:Static husk:ObjectConverters.NotMatch}"
                                            ConverterParameter="Updating"
                                            Path="State" />
                                        <Binding
                                            Converter="{x:Static husk:ObjectConverters.NotMatch}"
                                            ConverterParameter="Deploying"
                                            Path="State" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="12">
                                    <fi:SymbolIcon
                                        Grid.Column="0"
                                        Height="{StaticResource MediumFontSize}"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="FolderZip" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                        FontSize="{StaticResource SmallFontSize}"
                                        Text="{x:Static lang:Resources.InstancePage_ExportModpackLabelText}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding ManageSnapshotsAsyncCommand, FallbackValue={x:Null}}"
                                CornerRadius="{StaticResource ExtraSmallCornerRadius}"
                                ToolTip.Tip="{x:Static lang:Resources.InstancePage_ManageSnapshotsToolTipText}">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding
                                            Converter="{x:Static husk:ObjectConverters.Match}"
                                            ConverterParameter="Idle"
                                            Path="State" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="12">
                                    <fi:SymbolIcon
                                        Grid.Column="0"
                                        Height="{StaticResource MediumFontSize}"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="Storage" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                        FontSize="{StaticResource SmallFontSize}"
                                        Text="{x:Static lang:Resources.InstancePage_ManageSnapshotsLabelText}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding OpenFolderCommand}"
                                ToolTip.Tip="{x:Static lang:Resources.InstancePage_OpenFolderToolTipText}">
                                <Button.CornerRadius>
                                    <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.TopBottomCombinedMulti}">
                                        <StaticResource ResourceKey="ExtraSmallCornerRadius" />
                                        <StaticResource ResourceKey="MediumCornerRadius" />
                                    </MultiBinding>
                                </Button.CornerRadius>
                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    ColumnSpacing="12">
                                    <fi:SymbolIcon
                                        Grid.Column="0"
                                        Height="{StaticResource MediumFontSize}"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="FolderOpen" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                        FontSize="{StaticResource SmallFontSize}"
                                        Text="{x:Static lang:Resources.InstancePage_OpenFolderLabelText}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </StackPanel>
                        <Grid
                            Grid.Row="3"
                            Margin="12,0,12,12"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                Width="40"
                                Height="40"
                                BorderBrush="{StaticResource ControlBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="{StaticResource SmallCornerRadius}"
                                ToolTip.Tip="{Binding Basic.Name}">
                                <Border.Background>
                                    <ImageBrush
                                        Source="{Binding Basic.Thumbnail}"
                                        Stretch="Uniform" />
                                </Border.Background>
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ViewState?.IsSidebarExpanded, FallbackValue={x:False}}"
                                MaxLines="2"
                                Text="{Binding Basic.Name}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </Border>
                <Panel Grid.Column="1">
                    <husk:Frame x:Name="Frame" />
                </Panel>
            </Grid>
        </husk:DropContainer>
    </Panel>
</app:ScopedPage>
