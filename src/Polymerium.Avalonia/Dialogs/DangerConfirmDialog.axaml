<husk:Dialog
    x:Class="Polymerium.Avalonia.Dialogs.DangerConfirmDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="320"
    IsPrimaryButtonVisible="True"
    PrimaryText="{x:Static lang:Resources.Dialog_ConfirmButtonText}"
    Result="{Binding $self.TypedCode, Mode=OneWay}"
    mc:Ignorable="d">
    <StackPanel Spacing="12">
        <TextBlock
            FontSize="{StaticResource SmallFontSize}"
            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
            Text="{x:Static lang:Resources.DangerConfirmDialog_PromptText}"
            TextWrapping="Wrap" />
        <Border
            Padding="24,10"
            HorizontalAlignment="Center"
            Background="{StaticResource ControlTranslucentFullBackgroundBrush}"
            BorderBrush="{StaticResource ControlBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource MediumCornerRadius}">
            <TextBlock
                FontSize="30"
                FontWeight="{StaticResource ControlStrongFontWeight}"
                Text="{Binding $parent[app:DangerConfirmDialog].ChallengeCode, Mode=OneWay}" />
        </Border>
        <TextBox
            x:Name="CodeInput"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            PlaceholderText="{x:Static lang:Resources.DangerConfirmDialog_InputPlaceholderText}"
            Text="{Binding $parent[app:DangerConfirmDialog].TypedCode, Mode=TwoWay}" />
    </StackPanel>
</husk:Dialog>
