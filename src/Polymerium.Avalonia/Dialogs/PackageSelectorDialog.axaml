<husk:Dialog
    x:Class="Polymerium.Avalonia.Dialogs.PackageSelectorDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:TridentCore.Abstractions.Repositories.Resources;assembly=TridentCore.Abstractions"
    Width="540"
    d:DesignHeight="560"
    d:DesignWidth="540"
    IsPrimaryButtonVisible="True"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">
    <!--
        作用域划分：搜索条是全局/局部的分界线。
        之上（含 chip、搜索、清空全部）= 全局；之下（全选可见、清除可见、列表）= 局部。
        搜索只是帮用户定位项，不是状态也不是结果。
    -->
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

        <!--  GLOBAL：按类型/作者/标签快捷勾选（作用于全集）  -->
        <ScrollViewer
            Grid.Row="0"
            MaxHeight="120"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">
                <ItemsControl ItemsSource="{Binding $parent[app:PackageSelectorDialog].Types}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="resources:ResourceKind">
                            <Button
                                Padding="8,4"
                                Classes="Small"
                                Command="{Binding $parent[app:PackageSelectorDialog].SelectByTypeCommand}"
                                CommandParameter="{Binding}"
                                CornerRadius="{StaticResource FullCornerRadius}"
                                Theme="{StaticResource OutlineButtonTheme}">
                                <TextBlock Text="{Binding Converter={x:Static app:LocalizedEnumConverters.LocalizedResourceKind}}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemSpacing="6" LineSpacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding $parent[app:PackageSelectorDialog].Authors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="x:String">
                            <Button
                                Padding="8,4"
                                Classes="Small"
                                Command="{Binding $parent[app:PackageSelectorDialog].SelectByAuthorCommand}"
                                CommandParameter="{Binding}"
                                CornerRadius="{StaticResource FullCornerRadius}"
                                Theme="{StaticResource OutlineButtonTheme}">
                                <TextBlock Text="{Binding StringFormat=@{0}}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemSpacing="6" LineSpacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding $parent[app:PackageSelectorDialog].Tags}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="x:String">
                            <Button
                                Padding="8,4"
                                Classes="Small"
                                Command="{Binding $parent[app:PackageSelectorDialog].SelectByTagCommand}"
                                CommandParameter="{Binding}"
                                CornerRadius="{StaticResource FullCornerRadius}"
                                Theme="{StaticResource OutlineButtonTheme}">
                                <TextBlock Text="{Binding StringFormat=#{0}}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemSpacing="6" LineSpacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!--  GLOBAL：搜索 + 计数 + 清空全部（全集）  -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <TextBox
                Grid.Column="0"
                PlaceholderText="{x:Static lang:Resources.PackageSelectorDialog_SearchPlaceholder}"
                Text="{Binding $parent[app:PackageSelectorDialog].FilterText, Mode=TwoWay}">
                <TextBox.InnerLeftContent>
                    <StackPanel Orientation="Horizontal">
                        <fi:SymbolIcon
                            Margin="10,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="Search" />
                        <husk:Divider Orientation="Vertical" />
                    </StackPanel>
                </TextBox.InnerLeftContent>
                <TextBox.InnerRightContent>
                    <Button
                        IsVisible="{Binding $parent[TextBox].Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Command="{Binding $parent[TextBox].Clear}">
                        <fi:SymbolIcon
                            FontSize="{StaticResource MediumFontSize}"
                            Symbol="Dismiss" />
                    </Button>
                </TextBox.InnerRightContent>
            </TextBox>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                Text="{Binding $parent[app:PackageSelectorDialog].SelectionSummary}" />
            <Button
                Grid.Column="2"
                Classes="Small"
                Command="{Binding $parent[app:PackageSelectorDialog].ClearAllCommand}"
                ToolTip.Tip="{x:Static lang:Resources.PackageSelectorDialog_ClearAllText}">
                <husk:IconLabel
                    Icon="SelectAllOff"
                    Text="{x:Static lang:Resources.PackageSelectorDialog_ClearAllText}" />
            </Button>
        </Grid>

        <!--  LOCAL：全选可见 / 清除可见（作用于当前过滤视图）  -->
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Classes="Small"
                Command="{Binding $parent[app:PackageSelectorDialog].SelectAllVisibleCommand}"
                IsEnabled="{Binding $parent[app:PackageSelectorDialog].View.Count, Converter={x:Static husk:NumberConverters.IsNonZero}, FallbackValue=False}">
                <husk:IconLabel
                    Icon="CheckmarkSquare"
                    Text="{x:Static lang:Resources.PackageSelectorDialog_SelectAllVisibleText}" />
            </Button>
            <Button
                Classes="Small"
                Command="{Binding $parent[app:PackageSelectorDialog].ClearVisibleCommand}"
                IsEnabled="{Binding $parent[app:PackageSelectorDialog].View.Count, Converter={x:Static husk:NumberConverters.IsNonZero}, FallbackValue=False}">
                <husk:IconLabel
                    Icon="Square"
                    Text="{x:Static lang:Resources.PackageSelectorDialog_ClearVisibleText}" />
            </Button>
        </StackPanel>

        <!--  LOCAL：列表  -->
        <Panel Grid.Row="3">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding $parent[app:PackageSelectorDialog].View.Count, Converter={x:Static husk:NumberConverters.IsZero}, FallbackValue=True}"
                Spacing="8">
                <fi:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource ExtraLargeFontSize}"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Symbol="Box" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="{x:Static lang:Resources.PackageSelectorDialog_EmptyText}" />
            </StackPanel>
            <ScrollViewer
                MaxHeight="360"
                IsVisible="{Binding $parent[app:PackageSelectorDialog].View.Count, Converter={x:Static husk:NumberConverters.IsNonZero}, FallbackValue=False}">
                <ItemsControl ItemsSource="{Binding $parent[app:PackageSelectorDialog].View}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="app:SelectablePackageModel">
                            <Border
                                Margin="0,2"
                                Padding="12,8"
                                Background="{StaticResource LayerBackgroundBrush}"
                                CornerRadius="{StaticResource SmallCornerRadius}">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                                    <CheckBox
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    <Border
                                        Grid.Column="1"
                                        Width="32"
                                        Height="32"
                                        ClipToBounds="True"
                                        CornerRadius="{StaticResource SmallCornerRadius}">
                                        <Panel>
                                            <Image
                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                                Source="{Binding Thumbnail, FallbackValue={x:Null}}"
                                                Stretch="UniformToFill" />
                                            <fi:SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}, FallbackValue=True}"
                                                Symbol="Box" />
                                        </Panel>
                                    </Border>
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                        <TextBlock
                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                            Text="{Binding Label, FallbackValue=Package}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="{StaticResource SmallFontSize}"
                                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                            IsVisible="{Binding Author, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                            Text="{Binding Author, StringFormat=@{0}}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <husk:Tag
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        IsVisible="{Binding Kind, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                        Content="{Binding Kind, Converter={x:Static app:LocalizedEnumConverters.LocalizedResourceKind}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </Grid>
</husk:Dialog>
