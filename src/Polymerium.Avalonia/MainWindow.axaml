<husk:AppWindow
    x:Class="Polymerium.Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:fie="clr-namespace:FluentIcons.Avalonia.Markup;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Static app:Program.Brand}"
    Width="1111"
    Height="666"
    MinWidth="600"
    MinHeight="460"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="app:MainWindowContext"
    Icon="/Assets/Icon.App.ico"
    Loaded="Control_OnLoaded"
    Unloaded="Control_OnUnloaded"
    mc:Ignorable="d">
    <husk:AppWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!--  macOS Tahoe 风格侧边栏：Liquid Glass 毛玻璃背景 + 玻璃边缘描边 + 柔和浮起投影  -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush
                        x:Key="SidebarBackground"
                        Color="#bfffffff" />
                    <SolidColorBrush
                        x:Key="SidebarBorder"
                        Color="#14000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush
                        x:Key="SidebarBackground"
                        Color="#cc1e1e1e" />
                    <SolidColorBrush
                        x:Key="SidebarBorder"
                        Color="#14FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </husk:AppWindow.Resources>
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{x:Static lang:Resources.AppMenu_FileText}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem
                            Command="{Binding NewInstanceCommand}"
                            Gesture="Cmd+N"
                            Header="{x:Static lang:Resources.AppMenu_NewInstanceText}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem
                            Command="{Binding GoSettingsCommand}"
                            Gesture="Cmd+,"
                            Header="{x:Static lang:Resources.AppMenu_SettingsText}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            <NativeMenuItem Header="{x:Static lang:Resources.AppMenu_ViewText}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem
                            Command="{Binding GoHomeCommand}"
                            Header="{x:Static lang:Resources.AppMenu_HomeText}" />
                        <NativeMenuItem
                            Command="{Binding GoMarketplaceCommand}"
                            Header="{x:Static lang:Resources.AppMenu_MarketplaceText}" />
                        <NativeMenuItem
                            Command="{Binding GoAccountsCommand}"
                            Header="{x:Static lang:Resources.AppMenu_AccountsText}" />
                        <NativeMenuItem
                            Command="{Binding GoStorageCommand}"
                            Header="{x:Static lang:Resources.AppMenu_StorageText}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem
                            Command="{Binding ToggleFullScreenCommand}"
                            Gesture="F11"
                            Header="{x:Static lang:Resources.AppMenu_FullScreenText}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            <NativeMenuItem Header="{x:Static lang:Resources.AppMenu_HelpText}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem
                            Command="{Binding AboutCommand}"
                            Header="{x:Static lang:Resources.AppMenu_AboutText}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem
                            Command="{Binding CheckForUpdatesCommand}"
                            Header="{x:Static lang:Resources.AppMenu_CheckForUpdatesText}" />
                        <NativeMenuItem
                            Command="{Binding OpenGitHubCommand}"
                            Header="{x:Static lang:Resources.AppMenu_FeedbackText}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>
    <Grid Name="Container">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="83*" />
            <ColumnDefinition
                Width="27*"
                MinWidth="200"
                MaxWidth="400" />
        </Grid.ColumnDefinitions>
        <Border
            x:Name="Main"
            Grid.Column="0">
            <DockPanel>
                <Panel>
                    <husk:Frame x:Name="Root" />
                </Panel>
            </DockPanel>
        </Border>
        <Border
            x:Name="Sidebar"
            Grid.Column="1"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource SidebarBorder}"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid
                    x:Name="TitleBar"
                    DockPanel.Dock="Top"
                    IsVisible="{Binding $parent[app:MainWindow].IsTitleBarVisible, Mode=OneWay}"
                    ColumnDefinitions="*,Auto">
                    <Border
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Background="Transparent"
                        WindowDecorationProperties.ElementRole="TitleBar" />
                    <StackPanel Grid.Column="1">
                        <husk:ButtonGroup
                            IsVisible="{OnPlatform Default={x:True},
                                                   macOS={x:False}}"
                            BorderThickness="0">
                            <husk:ButtonGroup.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Padding" Value="10" />
                                </Style>
                                <Style Selector="fi|SymbolIcon">
                                    <Setter Property="FontSize" Value="10" />
                                </Style>
                                <Style Selector="husk|IconLabel">
                                    <Setter Property="FontSize" Value="10" />
                                </Style>
                            </husk:ButtonGroup.Styles>
                            <Button
                                Click="MinimizeButton_OnClick"
                                Cursor="{x:Null}"
                                WindowDecorationProperties.ElementRole="MinimizeButton">
                                <fi:SymbolIcon Symbol="Subtract" />
                            </Button>
                            <Button
                                Click="ToggleMaximizeButton_OnClick"
                                Cursor="{x:Null}"
                                WindowDecorationProperties.ElementRole="MaximizeButton">
                                <husk:SwitchContainer
                                    TargetType="x:Boolean"
                                    Value="{Binding $parent[husk:AppWindow].IsMaximized, Mode=OneWay}">
                                    <husk:SwitchCase Value="True">
                                        <fi:SymbolIcon Symbol="ArrowMinimize" />
                                    </husk:SwitchCase>
                                    <husk:SwitchCase Value="False">
                                        <fi:SymbolIcon Symbol="Maximize" />
                                    </husk:SwitchCase>
                                </husk:SwitchContainer>
                            </Button>
                            <Button
                                Click="CloseButton_OnClick"
                                Cursor="{x:Null}"
                                WindowDecorationProperties.ElementRole="CloseButton">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover fi|SymbolIcon">
                                        <Setter Property="Foreground" Value="{StaticResource ControlDangerForegroundBrush}" />
                                    </Style>
                                </Button.Styles>
                                <fi:SymbolIcon Symbol="Dismiss">
                                    <fi:SymbolIcon.Transitions>
                                        <Transitions>
                                            <BrushTransition
                                                Easing="SineEaseOut"
                                                Property="Foreground"
                                                Duration="{StaticResource ControlFasterAnimationDuration}" />
                                        </Transitions>
                                    </fi:SymbolIcon.Transitions>
                                </fi:SymbolIcon>
                            </Button>
                        </husk:ButtonGroup>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"
                        Orientation="Horizontal"
                        Spacing="6">
                        <StackPanel.Margin>
                            <OnPlatform
                                Default="12,0,0,-9"
                                macOS="72, 8, 0, -1" />
                        </StackPanel.Margin>
                        <StackPanel.Effect>
                            <DropShadowEffect
                                BlurRadius="6"
                                Opacity="0.1" />
                        </StackPanel.Effect>
                        <Image
                            Width="{StaticResource MediumFontSize}"
                            Height="{StaticResource MediumFontSize}"
                            VerticalAlignment="Center"
                            RenderOptions.BitmapInterpolationMode="HighQuality"
                            Source="/Assets/Icon.png" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource SmallFontSize}"
                            Text="{Binding $parent[Window].Title, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
                <Grid
                    Margin="9"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto"
                    RowSpacing="8">
                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Height="48"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Type app:LandingPage}"
                        Theme="{StaticResource OutlineButtonTheme}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <fi:SymbolIcon
                                VerticalAlignment="Center"
                                FontSize="18"
                                IconVariant="Color"
                                Symbol="Home" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Static lang:Resources.MainWindow_HomeButtonText}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Row="0"
                        Grid.Column="2"
                        Width="48"
                        Height="48"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Type app:NewInstancePage}"
                        Theme="{StaticResource OutlineButtonTheme}">
                        <fi:SymbolIcon
                            FontSize="18"
                            IconVariant="Color"
                            Symbol="AddStarburst" />
                    </Button>
                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Classes="Primary"
                        Height="36"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Type app:MarketplacePortalPage}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <fi:SymbolIcon
                                FontSize="18"
                                IconVariant="Color"
                                Symbol="BuildingStore" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Static lang:Resources.MainWindow_MarketplaceButtonText}" />
                        </StackPanel>
                    </Button>
                    <husk:Divider
                        Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3" />
                    <Grid
                        Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="8">
                        <Button
                            Grid.Column="0"
                            Classes="Small"
                            Command="{Binding OpenNotificationSidebarCommand}"
                            Theme="{StaticResource GhostButtonTheme}">
                            <husk:IconLabel
                                VerticalAlignment="Center"
                                Icon="Alert"
                                Text="{Binding UnreadNotificationCount}" />
                        </Button>
                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Classes="Small Primary"
                                IsVisible="{Binding CurrentUpdate, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Command="{Binding OpenUpdateModalCommand}"
                                CommandParameter="{Binding CurrentUpdate}">
                                <husk:IconLabel
                                    VerticalAlignment="Center"
                                    Icon="ArrowUp"
                                    Text="{x:Static lang:Resources.MainWindow_UpdateAvailableButtonText}" />
                            </Button>
                            <Button
                                Classes="Small"
                                Theme="{StaticResource GhostButtonTheme}">
                                <fi:SymbolIcon
                                    FontSize="{StaticResource MediumFontSize}"
                                    Symbol="MoreVertical" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem
                                            Command="{Binding AboutCommand}"
                                            Header="{x:Static lang:Resources.AppMenu_AboutText}" />
                                        <MenuItem
                                            Command="{Binding CheckForUpdatesCommand}"
                                            Header="{x:Static lang:Resources.AppMenu_CheckForUpdatesText}" />
                                        <MenuItem Header="-" />
                                        <MenuItem
                                            Command="{Binding OpenGitHubCommand}"
                                            Header="{x:Static lang:Resources.AppMenu_FeedbackText}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <husk:Divider
                        Grid.Row="4"
                        Grid.Column="0"
                        Grid.ColumnSpan="3" />
                    <TextBox
                        Grid.Row="5"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        PlaceholderText="{x:Static lang:Resources.MainWindow_InstanceFilterPlaceholder}"
                        Text="{Binding FilterText, Mode=TwoWay}">
                        <TextBox.InnerRightContent>
                            <Button
                                IsVisible="{Binding $parent[TextBox].Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Command="{Binding $parent[TextBox].Clear}"
                                Content="{fie:SymbolIcon Symbol=Dismiss,
                                                         FontSize={StaticResource MediumFontSize}}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}" />
                        </TextBox.InnerRightContent>
                    </TextBox>
                    <husk:DropContainer
                        Grid.Row="6"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        DragOver="DropContainer_OnDragOver"
                        Drop="DropContainer_OnDrop">
                        <husk:DropContainer.Overlay>
                            <Panel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Rectangle
                                    Fill="{StaticResource ControlInteractiveBackgroundBrush}"
                                    RadiusX="6"
                                    RadiusY="6"
                                    Stroke="{StaticResource ControlInteractiveBorderBrush}"
                                    StrokeDashArray="6,2"
                                    StrokeJoin="Round"
                                    StrokeLineCap="Round"
                                    StrokeThickness="2" />
                                <StackPanel
                                    Margin="24,18"
                                    Opacity="{StaticResource Overlay1Opacity}"
                                    Spacing="12">
                                    <fi:SymbolIcon
                                        HorizontalAlignment="Center"
                                        FontSize="36"
                                        Foreground="{StaticResource ControlWhiteForegroundBrush}"
                                        Symbol="CubeAdd" />
                                </StackPanel>
                            </Panel>
                        </husk:DropContainer.Overlay>
                        <Panel>
                            <StackPanel
                                VerticalAlignment="Center"
                                IsVisible="{Binding View.Count, Converter={x:Static husk:NumberConverters.IsZero}, FallbackValue=True}"
                                Spacing="8">
                                <fi:SymbolIcon
                                    HorizontalAlignment="Center"
                                    FontSize="{StaticResource ExtraLargeFontSize}"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Symbol="Cube" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="{StaticResource LargeFontSize}"
                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                    Text="{x:Static lang:Resources.Shared_EmptyListLabelText}" />
                            </StackPanel>
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding View}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="app:InstanceEntryModel">
                                            <app:InstanceEntryButton
                                                Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).ViewInstanceCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding Basic.Key}"
                                                State="{Binding State, Mode=OneWay}">
                                                <app:InstanceEntryButton.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).PlayCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_PlayMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=Rocket,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).DeployCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_DeployMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=SettingsCogMultiple,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem Header="-" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).ExportInstanceCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_ExportModpackMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=FolderZip,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).OpenFolderCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_OpenFolderMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=FolderOpen,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem Header="-" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).GotoSetupCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_SetupMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=BoxMultiple,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                        <MenuItem
                                                            Command="{Binding $parent[app:MainWindow].((app:MainWindowContext)DataContext).GotoPropertiesCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding Basic.Key}"
                                                            Header="{x:Static lang:Resources.MainWindow_PropertiesMenuText}"
                                                            Icon="{fie:SymbolIcon Symbol=WrenchScrewdriver,
                                                                                  FontSize={StaticResource MediumFontSize}}" />
                                                    </MenuFlyout>
                                                </app:InstanceEntryButton.ContextFlyout>
                                            </app:InstanceEntryButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Panel>
                    </husk:DropContainer>
                    <husk:Divider
                        Grid.Row="7"
                        Grid.Column="0"
                        Grid.ColumnSpan="3" />
                    <Button
                        Grid.Row="8"
                        Grid.Column="0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Type app:SettingsPage}"
                        Theme="{StaticResource OutlineButtonTheme}">
                        <fi:SymbolIcon
                            FontSize="18"
                            IconVariant="Color"
                            Symbol="Settings" />
                    </Button>
                    <Button
                        Grid.Row="8"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Type app:AccountsPage}"
                        Theme="{StaticResource OutlineButtonTheme}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <fi:SymbolIcon
                                FontSize="18"
                                IconVariant="Color"
                                Symbol="People" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Static lang:Resources.MainWindow_AccountButtonText}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</husk:AppWindow>
