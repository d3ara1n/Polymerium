<husk:Modal
    x:Class="Polymerium.Avalonia.Modals.ProgressModal"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="360"
    d:DesignHeight="300"
    d:DesignWidth="400"
    Classes="Frosted"
    mc:Ignorable="d">
    <Border
        Padding="24"
        Background="{DynamicResource ControlSolidBackgroundBrush}"
        CornerRadius="{StaticResource MediumCornerRadius}">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16">
            <husk:ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                IsIndeterminate="{Binding $parent[app:ProgressModal].IsIndeterminate}"
                Value="{Binding $parent[app:ProgressModal].ProgressValue}" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="{StaticResource LargeFontSize}"
                FontWeight="{StaticResource ControlStrongFontWeight}"
                Text="{Binding $parent[app:ProgressModal].Title}" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="{StaticResource SmallFontSize}"
                Foreground="{DynamicResource ControlSecondaryForegroundBrush}"
                Text="{Binding $parent[app:ProgressModal].StatusText}" />
        </StackPanel>
    </Border>
</husk:Modal>
