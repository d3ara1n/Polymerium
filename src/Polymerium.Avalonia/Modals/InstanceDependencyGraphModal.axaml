<husk:Modal
    x:Class="Polymerium.Avalonia.Modals.InstanceDependencyGraphModal"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:agc="clr-namespace:AvaloniaGraphControl;assembly=AvaloniaGraphControl"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:async="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:modalModels="clr-namespace:Polymerium.Avalonia.ModalModels"
    xmlns:models="clr-namespace:Polymerium.Avalonia.Models"
    Padding="8"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:DesignHeight="600"
    d:DesignWidth="900"
    x:DataType="modalModels:InstanceDependencyGraphModalModel"
    mc:Ignorable="d">
    <husk:Modal.Resources>
        <DataTemplate
            x:Key="DependencyEntryTemplate"
            x:DataType="models:DependencyEntry">
            <Button
                Classes="Small"
                Padding="8,6"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                Command="{Binding $parent[app:InstanceDependencyGraphModal].((app:InstanceDependencyGraphModalModel)DataContext)?.SelectNodeCommand}"
                CommandParameter="{Binding Key}"
                CornerRadius="{StaticResource SmallCornerRadius}"
                Cursor="Hand">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="{Binding ProjectName}"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4">
                        <husk:Tag
                            Classes="Status Danger"
                            IsVisible="{Binding IsMissing}">
                            <TextBlock Text="{x:Static lang:Resources.InstanceDependencyGraphModal_MissingTagText}" />
                        </husk:Tag>
                        <husk:Tag
                            Classes="Status"
                            IsVisible="{Binding IsRequired}">
                            <TextBlock Text="{x:Static lang:Resources.InstanceDependencyGraphModal_RequiredTagText}" />
                        </husk:Tag>
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </husk:Modal.Resources>
    <Grid ColumnDefinitions="*,Auto">
        <app:ZoomView
            x:Name="ZoomView"
            Grid.Column="0"
            Background="{StaticResource ControlTranslucentHalfBackgroundBrush}"
            MaxZoom="10"
            MinZoom="0.1"
            ZoomSpeed="1.2">
            <app:ZoomView.CornerRadius>
                <MultiBinding Converter="{x:Static husk:CornerRadiusConverters.ToInnerRadiusMulti}">
                    <Binding Path="CornerRadius"
                             RelativeSource="{RelativeSource FindAncestor, AncestorType=husk:Modal}" />
                    <Binding Path="Padding"
                             RelativeSource="{RelativeSource FindAncestor, AncestorType=husk:Modal}" />
                </MultiBinding>
            </app:ZoomView.CornerRadius>
            <agc:GraphPanel
                x:Name="GraphPanel"
                Graph="{Binding DependencyGraph}"
                LayoutMethod="SugiyamaScheme">
                <agc:GraphPanel.DataTemplates>
                    <DataTemplate
                        x:DataType="models:DependencyGraphNode"
                        DataType="models:DependencyGraphNode">
                        <app:DependencyGraphCard
                            Command="{Binding $parent[app:InstanceDependencyGraphModal].((app:InstanceDependencyGraphModalModel)DataContext)?.SelectNodeCommand}"
                            CommandParameter="{Binding Key}"
                            IsMissing="{Binding IsMissing, Mode=OneWay}"
                            IsSelected="{Binding IsSelected, Mode=OneWay}">
                            <Grid
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="10">
                                <Border
                                    Grid.Column="0"
                                    Height="32"
                                    Width="32"
                                    VerticalAlignment="Center"
                                    CornerRadius="{StaticResource SmallCornerRadius}">
                                    <Image
                                        async:ImageLoader.Source="{Binding Thumbnail}"
                                        Stretch="UniformToFill" />
                                </Border>
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        FontSize="{StaticResource MediumFontSize}"
                                        FontWeight="{StaticResource ControlStrongFontWeight}"
                                        Text="{Binding ProjectName, FallbackValue=Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="{StaticResource SmallFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{Binding Author, StringFormat={}@{0}}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="2">
                                    <fi:SymbolIcon
                                        FontSize="{StaticResource CaptionFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Symbol="ArrowDown" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource CaptionFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{Binding PrerequisiteCount}" />
                                    <fi:SymbolIcon
                                        Margin="4,0,0,0"
                                        FontSize="{StaticResource CaptionFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Symbol="ArrowUp" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource CaptionFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="{Binding DependentCount}" />
                                </StackPanel>
                            </Grid>
                        </app:DependencyGraphCard>
                    </DataTemplate>
                </agc:GraphPanel.DataTemplates>
            </agc:GraphPanel>
        </app:ZoomView>

        <!--  右侧详情面板  -->
        <Border
            Grid.Column="1"
            MinWidth="300"
            MaxWidth="340"
            Margin="8,0,0,0"
            Padding="16"
            VerticalAlignment="Stretch"
            IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}"
            Background="{StaticResource ControlFillColorDefaultBrush}"
            CornerRadius="{StaticResource SmallCornerRadius}">
            <Grid
                RowDefinitions="Auto,Auto,Auto,*"
                RowSpacing="12">
                <!--  头部：缩略图 + 包名 + 作者 + 关闭按钮  -->
                <Grid
                    Grid.Row="0"
                    ColumnDefinitions="48,*,Auto"
                    ColumnSpacing="12">
                    <Border
                        Grid.Column="0"
                        Width="48"
                        Height="48"
                        CornerRadius="{StaticResource SmallCornerRadius}">
                        <Border.Background>
                            <ImageBrush
                                async:ImageBrushLoader.Source="{Binding SelectedNode?.Thumbnail}"
                                Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock
                            FontSize="{StaticResource LargeFontSize}"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding SelectedNode.ProjectName}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{Binding SelectedNode.Author, StringFormat={}@{0}}" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        Classes="Small"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding SelectNodeCommand}"
                        CommandParameter="{x:Null}"
                        CornerRadius="{StaticResource FullCornerRadius}"
                        Cursor="Hand">
                        <fi:SymbolIcon
                            FontSize="{StaticResource MediumFontSize}"
                            Symbol="ChevronRight" />
                    </Button>
                </Grid>

                <!--  元信息行  -->
                <StackPanel
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="6">
                    <husk:Tag>
                        <TextBlock
                            Text="{Binding SelectedNode?.Kind, Converter={x:Static app:LocalizedEnumConverters.LocalizedResourceKind}}" />
                    </husk:Tag>
                    <husk:Tag>
                        <TextBlock
                            Text="{Binding SelectedNode?.ReleaseType, Converter={x:Static app:LocalizedEnumConverters.LocalizedReleaseType}}" />
                    </husk:Tag>
                </StackPanel>

                <Separator Grid.Row="2" />

                <!--  前置 / 附属（Tab）  -->
                <TabControl Grid.Row="3">
                    <TabItem Header="{x:Static lang:Resources.InstanceDependencyGraphModal_PrerequisitesTitle}">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <StackPanel
                                Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Text="{x:Static lang:Resources.InstanceDependencyGraphModal_PrerequisitesTitle}" />
                                <husk:Tag Classes="Status">
                                    <TextBlock Text="{Binding SelectedPrerequisites.Count}" />
                                </husk:Tag>
                            </StackPanel>
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl
                                    ItemsSource="{Binding SelectedPrerequisites}"
                                    ItemTemplate="{StaticResource DependencyEntryTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{x:Static lang:Resources.InstanceDependencyGraphModal_DependentsTitle}">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <StackPanel
                                Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                    Text="{x:Static lang:Resources.InstanceDependencyGraphModal_DependentsTitle}" />
                                <husk:Tag Classes="Status">
                                    <TextBlock Text="{Binding SelectedDependents.Count}" />
                                </husk:Tag>
                            </StackPanel>
                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl
                                    ItemsSource="{Binding SelectedDependents}"
                                    ItemTemplate="{StaticResource DependencyEntryTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!--  加载指示  -->
        <husk:ProgressRing
            Grid.Column="0"
            Width="32"
            Height="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsLoading}"
            IsIndeterminate="True"
            Theme="{StaticResource SolidProgressRingTheme}" />

        <!--  关闭按钮  -->
        <Button
            Grid.Column="0"
            Classes="Small"
            Margin="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Command="{Binding $parent[app:InstanceDependencyGraphModal].Dismiss}"
            CornerRadius="{StaticResource FullCornerRadius}"
            IsCancel="True">
            <fi:SymbolIcon
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                Symbol="Dismiss" />
        </Button>

        <!--  统计卡片  -->
        <Border
            Grid.Column="0"
            Margin="8"
            Padding="12,8"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="{StaticResource ControlFillColorDefaultBrush}"
            CornerRadius="{StaticResource SmallCornerRadius}">
            <StackPanel
                Orientation="Horizontal"
                Spacing="16">
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Text="{Binding VisiblePackages}" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Text="{x:Static lang:Resources.InstanceDependencyGraphModal_VisiblePackagesLabel}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="{Binding TotalPackages}" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.InstanceDependencyGraphModal_TotalPackagesLabel}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{Binding HiddenPackages}" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.InstanceDependencyGraphModal_HiddenPackagesLabel}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{Binding EdgeCount}" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{x:Static lang:Resources.InstanceDependencyGraphModal_DependencyCountLabel}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Foreground="{StaticResource ControlDangerForegroundBrush}"
                        Text="{Binding MissingCount}" />
                    <TextBlock
                        FontSize="{StaticResource SmallFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Foreground="{StaticResource ControlDangerForegroundBrush}"
                        Text="{x:Static lang:Resources.InstanceDependencyGraphModal_MissingCountLabel}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</husk:Modal>
