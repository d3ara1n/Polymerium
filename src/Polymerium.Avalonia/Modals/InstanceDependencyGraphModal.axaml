<husk:Modal
    x:Class="Polymerium.Avalonia.Modals.InstanceDependencyGraphModal"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:agc="clr-namespace:AvaloniaGraphControl;assembly=AvaloniaGraphControl"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:modalModels="clr-namespace:Polymerium.Avalonia.ModalModels"
    xmlns:models="clr-namespace:Polymerium.Avalonia.Models"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    x:DataType="modalModels:InstanceDependencyGraphModalModel"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Padding="8"
    mc:Ignorable="d">
    <!--
        ModalModel 模式：DataContext 为 InstanceDependencyGraphModalModel（由 PopModal<T> 通过
        SimpleViewActivator 自动配对、注入 DI、挂 ViewModelMixin）。绑定直接走 {Binding}。

        布局：ZoomView 满铺 modal（仅留 8px 边距），所有辅助控件浮动其上。
            - 右上角：关闭按钮
            - 右下角：预留给 QoL 控件（小地图 / 滚动条 / 缩放等级滑条 / 回到自适应按钮）
        Grid 中后声明的子元素位于上层，因此 ZoomView 先声明、浮动控件后声明。
    -->
    <Grid>
        <!--  底层：ZoomView + GraphPanel（满铺）  -->
        <app:ZoomView
            x:Name="ZoomView"
            Background="{StaticResource CardBackgroundBrush}"
            MaxZoom="10"
            MinZoom="0.1"
            CornerRadius="{StaticResource SmallCornerRadius}"
            ZoomSpeed="1.2">
            <agc:GraphPanel
                x:Name="GraphPanel"
                Graph="{Binding DependencyGraph}"
                LayoutMethod="SugiyamaScheme">
                <agc:GraphPanel.DataTemplates>
                    <DataTemplate
                        x:DataType="models:DependencyGraphNode"
                        DataType="models:DependencyGraphNode">
                        <Border
                            Padding="12,6"
                            Background="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}"
                            BorderBrush="{StaticResource ControlAccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock FontSize="13" Text="{Binding Label}" />
                        </Border>
                    </DataTemplate>
                </agc:GraphPanel.DataTemplates>
            </agc:GraphPanel>
        </app:ZoomView>

        <!--  浮动层·右上：关闭按钮（与 AccountEntryModal 同样式）  -->
        <Button
            Margin="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Classes="Small"
            Command="{Binding $parent[app:InstanceDependencyGraphModal].Dismiss}"
            CornerRadius="{StaticResource FullCornerRadius}"
            IsCancel="True">
            <fi:SymbolIcon
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                Symbol="Dismiss" />
        </Button>

        <!--
            浮动层·右下：QoL 控件区。集中在此避免与 ZoomView 内容遮挡。
            后续滚动条 / 小地图 / 缩放等级滑条陆续加入本区。
        -->
        <StackPanel
            Margin="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Orientation="Horizontal"
            Spacing="4">
            <!--  全视图（contain fit）：整图可见  -->
            <Button
                Classes="Small"
                Command="{Binding $parent[app:InstanceDependencyGraphModal].FitToAllCommand}"
                ToolTip.Tip="全视图">
                <fi:SymbolIcon FontSize="{StaticResource MediumFontSize}" Symbol="ArrowMinimize" />
            </Button>
            <!--  自适应（cover fit）：短维充满、长维溢出  -->
            <Button
                Classes="Small"
                Command="{Binding $parent[app:InstanceDependencyGraphModal].FitToContentCommand}"
                ToolTip.Tip="自适应">
                <fi:SymbolIcon FontSize="{StaticResource MediumFontSize}" Symbol="ArrowExpand" />
            </Button>
        </StackPanel>
    </Grid>
</husk:Modal>
