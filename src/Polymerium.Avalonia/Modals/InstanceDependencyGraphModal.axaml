<husk:Modal
    x:Class="Polymerium.Avalonia.Modals.InstanceDependencyGraphModal"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:agc="clr-namespace:AvaloniaGraphControl;assembly=AvaloniaGraphControl"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:modalModels="clr-namespace:Polymerium.Avalonia.ModalModels"
    xmlns:models="clr-namespace:Polymerium.Avalonia.Models"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    x:DataType="modalModels:InstanceDependencyGraphModalModel"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <!--
        ModalModel 模式：DataContext 为 InstanceDependencyGraphModalModel（由 PopModal<T> 通过
        SimpleViewActivator 自动配对、注入 DI、挂 ViewModelMixin）。绑定直接走 {Binding}。
        ZoomView：自研缩放容器，直接滚轮缩放（鼠标为锚）+ 中键拖拽平移 + 无限平移。
    -->
    <DockPanel VerticalSpacing="12">
        <!--  Footer: 关闭按钮（项目通用约定）  -->
        <StackPanel
            DockPanel.Dock="Bottom"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Command="{Binding $parent[app:InstanceDependencyGraphModal].Dismiss}"
                Content="{x:Static lang:Resources.Dialog_DismissButtonText}"
                IsCancel="True" />
        </StackPanel>
        <!--  主体：自研 ZoomView + GraphPanel  -->
        <app:ZoomView
            x:Name="ZoomView"
            Background="{StaticResource CardBackgroundBrush}"
            MaxZoom="10"
            MinZoom="0.1"
            ZoomSpeed="1.2">
            <agc:GraphPanel
                x:Name="GraphPanel"
                Graph="{Binding DependencyGraph}"
                LayoutMethod="SugiyamaScheme">
                <agc:GraphPanel.DataTemplates>
                    <DataTemplate
                        x:DataType="models:DependencyGraphNode"
                        DataType="models:DependencyGraphNode">
                        <Border
                            Padding="12,6"
                            Background="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}"
                            BorderBrush="{StaticResource ControlAccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock FontSize="13" Text="{Binding Label}" />
                        </Border>
                    </DataTemplate>
                </agc:GraphPanel.DataTemplates>
            </agc:GraphPanel>
        </app:ZoomView>
    </DockPanel>
</husk:Modal>
