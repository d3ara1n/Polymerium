<husk:Modal
    x:Class="Polymerium.Avalonia.Modals.JarInJarScannerWidgetModal"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:lang="https://github.com/d3ara1n/Polymerium/Languages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:modalModels="clr-namespace:Polymerium.Avalonia.ModalModels"
    xmlns:models="clr-namespace:Polymerium.Avalonia.Models"
    Padding="8"
    d:DesignHeight="520"
    d:DesignWidth="720"
    x:DataType="modalModels:JarInJarScannerWidgetModalModel"
    Classes="Frosted"
    mc:Ignorable="d">
    <husk:Modal.Resources>
        <DataTemplate
            x:Key="HiddenModRowTemplate"
            x:DataType="models:HiddenModEntry">
            <app:HiddenModCard
                Margin="0,2"
                Duplicate="{Binding Duplicate}">
                <StackPanel Spacing="5">
                    <!--  主行：ModId + 徽标组  -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding ModId}"
                            TextTrimming="CharacterEllipsis" />
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                            <husk:Tag IsVisible="{Binding Loader, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding Loader}" />
                            </husk:Tag>
                            <husk:Tag IsVisible="{Binding Version, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding Version}" />
                            </husk:Tag>
                        </StackPanel>
                    </Grid>
                    <!--  Name 次行  -->
                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis" />
                    <!--  宿主溯源行  -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="6">
                        <fi:SymbolIcon
                            VerticalAlignment="Center"
                            FontSize="{StaticResource SmallFontSize}"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Symbol="BoxMultiple" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="{x:Static lang:Resources.JarInJarScannerModal_EmbeddedInHeader}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="{StaticResource ControlStrongFontWeight}"
                            Text="{Binding Host}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </app:HiddenModCard>
        </DataTemplate>
    </husk:Modal.Resources>

    <DockPanel>
        <!--  标题栏  -->
        <DockPanel
            DockPanel.Dock="Top"
            Margin="8,8,8,4">
            <Button
                DockPanel.Dock="Right"
                Classes="Small"
                Command="{Binding $parent[app:JarInJarScannerWidgetModal].Dismiss}"
                CornerRadius="{StaticResource FullCornerRadius}"
                IsCancel="True">
                <fi:SymbolIcon
                    Width="{StaticResource MediumFontSize}"
                    Height="{StaticResource MediumFontSize}"
                    FontSize="{StaticResource MediumFontSize}"
                    Symbol="Dismiss" />
            </Button>
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource LargeFontSize}"
                FontWeight="{StaticResource ControlStrongFontWeight}"
                Text="{x:Static lang:Resources.JarInJarScannerModal_Title}" />
        </DockPanel>

        <husk:SwitchContainer
            Margin="8"
            Value="{Binding Status}">
            <!--  Idle 态  -->
            <husk:SwitchCase Value="Idle">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="440"
                    Spacing="16">
                    <fi:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Symbol="DrinkBottle" />
                    <TextBlock
                        LineHeight="20"
                        Text="{x:Static lang:Resources.JarInJarScannerModal_Description}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        Classes="Primary"
                        HorizontalAlignment="Center"
                        Command="{Binding ScanCommand}">
                        <husk:IconLabel
                            Icon="FolderSearch"
                            Text="{x:Static lang:Resources.JarInJarScannerModal_ScanButton}" />
                    </Button>
                </StackPanel>
            </husk:SwitchCase>

            <!--  Scanning 态  -->
            <husk:SwitchCase Value="Scanning">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="520"
                    Spacing="12">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <husk:ProgressRing
                            Width="16"
                            Height="16"
                            IsIndeterminate="True" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{x:Static lang:Resources.JarInJarScannerModal_ScanningTitle}" />
                    </StackPanel>
                    <ProgressBar
                        HorizontalAlignment="Stretch"
                        Maximum="{Binding TotalCount}"
                        Value="{Binding ScannedCount}" />
                    <TextBlock HorizontalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="ScannedCount" />
                                <Binding Path="TotalCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource SmallFontSize}"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="{Binding CurrentFile}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Classes="Small"
                        HorizontalAlignment="Center"
                        Command="{Binding CancelCommand}">
                        <TextBlock Text="{x:Static lang:Resources.JarInJarScannerModal_CancelButton}" />
                    </Button>
                </StackPanel>
            </husk:SwitchCase>

            <!--  Empty 态  -->
            <husk:SwitchCase Value="Empty">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <fi:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Symbol="Search" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="{x:Static lang:Resources.JarInJarScannerModal_EmptyTitle}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        MaxWidth="360"
                        Text="{x:Static lang:Resources.JarInJarScannerModal_EmptyDescription}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Center"
                        Command="{Binding ScanCommand}">
                        <husk:IconLabel
                            Icon="ArrowSync"
                            Text="{x:Static lang:Resources.JarInJarScannerModal_RescanButton}" />
                    </Button>
                </StackPanel>
            </husk:SwitchCase>

            <!--  Result 态  -->
            <husk:SwitchCase Value="Result">
                <DockPanel>
                    <!--  汇总徽标 + Rescan  -->
                    <Grid
                        DockPanel.Dock="Top"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="8"
                        Margin="0,0,0,8">
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8">
                            <husk:Tag>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="◇" />
                                    <TextBlock Text="{Binding JarFileCount}" />
                                    <TextBlock Text="{x:Static lang:Resources.JarInJarScannerModal_JarFilesLabel}" />
                                </StackPanel>
                            </husk:Tag>
                            <husk:Tag>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="◆" />
                                    <TextBlock Text="{Binding HiddenModCount}" />
                                    <TextBlock Text="{x:Static lang:Resources.JarInJarScannerModal_HiddenModsLabel}" />
                                </StackPanel>
                            </husk:Tag>
                            <husk:Tag
                                Classes="Status Warning"
                                IsVisible="{Binding HasDuplicates}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding DuplicateCount}" />
                                    <TextBlock Text="{x:Static lang:Resources.JarInJarScannerModal_DuplicateLabel}" />
                                </StackPanel>
                            </husk:Tag>
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Classes="Small"
                            VerticalAlignment="Center"
                            Command="{Binding ScanCommand}">
                            <husk:IconLabel
                                Icon="ArrowSync"
                                Text="{x:Static lang:Resources.JarInJarScannerModal_RescanButton}" />
                        </Button>
                    </Grid>

                    <!--  搜索条  -->
                    <TextBox
                        DockPanel.Dock="Top"
                        Margin="0,0,0,8"
                        Text="{Binding SearchText}"
                        PlaceholderText="{x:Static lang:Resources.JarInJarScannerModal_SearchPlaceholder}" />

                    <!--  清单  -->
                    <ScrollViewer>
                        <ItemsControl
                            ItemTemplate="{StaticResource HiddenModRowTemplate}"
                            ItemsSource="{Binding FilteredView}" />
                    </ScrollViewer>
                </DockPanel>
            </husk:SwitchCase>
        </husk:SwitchContainer>
    </DockPanel>
</husk:Modal>
