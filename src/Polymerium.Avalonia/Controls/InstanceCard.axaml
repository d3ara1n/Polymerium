<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:conv="clr-namespace:Polymerium.Avalonia.Converters"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">
    <Design.PreviewWith>
        <Panel>
            <StackPanel Margin="24">
                <app:InstanceCard Width="220" />
            </StackPanel>
        </Panel>
    </Design.PreviewWith>
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="CardBackdropStartColor">#FFE3F2</Color>
            <Color x:Key="CardBackdropEndColor">#E1E8FD</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="CardBackdropStartColor">#2B2B40</Color>
            <Color x:Key="CardBackdropEndColor">#1E1E30</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    <ControlTheme
        x:Key="{x:Type app:InstanceCard}"
        TargetType="app:InstanceCard">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource LargeCornerRadius}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="Template">
            <ControlTemplate x:DataType="app:InstanceCardModel">
                <Border
                    Name="Background"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <StackPanel
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            Spacing="10">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        Width="56"
                                        Height="56"
                                        CornerRadius="{StaticResource MediumCornerRadius}"
                                        ClipToBounds="True">
                                    <Panel>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                    <GradientStop Offset="0"
                                                                  Color="{DynamicResource CardBackdropStartColor}" />
                                                    <GradientStop Offset="1"
                                                                  Color="{DynamicResource CardBackdropEndColor}" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Border CornerRadius="{StaticResource SmallCornerRadius}"
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <Border.Background>
                                                <ImageBrush
                                                    Source="{Binding Basic.Thumbnail, FallbackValue={x:Null}}"
                                                    Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                    </Panel>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock
                                        FontSize="{StaticResource SmallFontSize}"
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        MaxLines="1"
                                        Text="{Binding Basic.SourceLabel,Converter={x:Static husk:StringConverters.ToUpper}, FallbackValue=LOCAL}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="{StaticResource LargeFontSize}"
                                        FontWeight="{StaticResource ControlStrongFontWeight}"
                                        MaxLines="2"
                                        Text="{Binding Basic.Name, FallbackValue=NAME}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <TextBlock
                                FontSize="{StaticResource SmallFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                TextTrimming="CharacterEllipsis">
                                <Run Text="..." />
                                <Run Text="{Binding Basic.LoaderLabel, FallbackValue=Vanilla}" />
                                <Run Text="·" />
                                <Run Text="{Binding Basic.Version, FallbackValue=Unknown}" />
                            </TextBlock>
                            <ItemsControl
                                IsVisible="{Binding Tags.Count, Converter={x:Static husk:NumberConverters.IsNonZero}}"
                                ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemSpacing="4" LineSpacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border
                                            Padding="6,3"
                                            Background="{StaticResource LayerBackgroundBrush}"
                                            BorderBrush="{StaticResource ControlBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource ExtraSmallCornerRadius}">
                                            <StackPanel
                                                Orientation="Horizontal"
                                                Spacing="4">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{Binding Converter={x:Static conv:InternalConverters.TagToBrush}}" />
                                                <TextBlock
                                                    FontSize="{StaticResource SmallFontSize}"
                                                    Text="{Binding}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock
                                FontSize="{StaticResource SmallFontSize}"
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="{Binding LastPlayedAt, FallbackValue=Unknown}" />
                        </StackPanel>
                        <Border
                            Name="PinnedBadge"
                            Margin="8"
                            Padding="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{StaticResource ControlAccentBackgroundBrush}"
                            CornerRadius="{StaticResource SmallCornerRadius}"
                            IsVisible="{Binding IsPinned}">
                            <fi:SymbolIcon
                                FontSize="{StaticResource SmallFontSize}"
                                Foreground="White"
                                Symbol="Pin" />
                        </Border>
                        <Border
                            Name="Border"
                            BorderBrush="{StaticResource ControlAccentInteractiveBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <TransformOperationsTransition
                                        Easing="SineEaseOut"
                                        Property="RenderTransform"
                                        Duration="{StaticResource ControlInstantAnimationDuration}" />
                                    <DoubleTransition
                                        Easing="SineEaseOut"
                                        Property="Opacity"
                                        Duration="{StaticResource ControlInstantAnimationDuration}" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Border">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scale(1.04,1.05)" />
        </Style>
        <Style Selector="^:pressed /template/ Border#Border">
            <Setter Property="RenderTransform" Value="scale(1.01)" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
