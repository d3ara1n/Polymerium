<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">
    <Design.PreviewWith>
        <husk:Page
            Width="128"
            Height="128">
            <Button
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <fi:SymbolIcon
                    FontSize="12"
                    Symbol="ArrowLeft" />
            </Button>
        </husk:Page>
    </Design.PreviewWith>

    <BoxShadows x:Key="PageBoxShadow">0 0 8 0 #19000000</BoxShadows>

    <ControlTheme
        x:Key="{x:Type husk:Page}"
        BasedOn="{StaticResource {x:Type husk:Page}}"
        TargetType="husk:Page">
        <Setter Property="Background" Value="{StaticResource LayerBackgroundBrush}" />
    </ControlTheme>
</ResourceDictionary>
