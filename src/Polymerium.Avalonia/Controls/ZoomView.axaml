<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium">

    <ControlTheme
        x:Key="{x:Type app:ZoomView}"
        TargetType="app:ZoomView">
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <!--  承载用户内容，RenderTransform 由 code-behind 设在 Content 上（而非此 Presenter）  -->
                        <ContentPresenter
                            x:Name="PART_ContentPresenter"
                            Background="Transparent"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />

                    <!--  浮动层·底部：水平滚动条（不可水平滚动时由代码隐藏）  -->
                    <ScrollBar
                        x:Name="PART_HScrollBar"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Visibility="Hidden" />

                    <!--  浮动层·右侧：垂直滚动条（不可垂直滚动时由代码隐藏）  -->
                    <ScrollBar
                        x:Name="PART_VScrollBar"
                        Margin="0,2,2,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Orientation="Vertical"
                        Visibility="Hidden" />

                    <!--
                        浮动层·右下：QoL 控件占位（小地图 / 缩放等级），
                        待后续实现，与外部工具栏错开避免遮挡。
                    -->
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
