<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="https://github.com/d3ara1n/Polymerium"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia">

    <ControlTheme
        x:Key="{x:Type app:ZoomView}"
        TargetType="app:ZoomView">
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <ContentPresenter
                            x:Name="PART_ContentPresenter"
                            Background="Transparent"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />

                        <!--  水平滚动条  -->
                        <ScrollBar
                            x:Name="PART_HScrollBar"
                            Margin="0,0,204,2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal"
                            Visibility="Hidden" />

                        <!--  垂直滚动条  -->
                        <ScrollBar
                            x:Name="PART_VScrollBar"
                            Margin="0,2,2,172"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Orientation="Vertical"
                            Visibility="Hidden" />

                        <!--  右下控件区  -->
                        <StackPanel
                            Margin="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Spacing="8">
                            <app:ZoomMinimap
                                x:Name="PART_Minimap"
                                Width="180"
                                Height="120"
                                ContentSize="{TemplateBinding ContentSize}"
                                ViewportRect="{TemplateBinding ViewportRect}" />

                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="4">
                                <Button
                                    Classes="Small"
                                    Padding="6,4"
                                    Command="{Binding ZoomOut, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="-" />
                                <Slider
                                    x:Name="PART_ZoomSlider"
                                    Width="120"
                                    VerticalAlignment="Center"
                                    LargeChange="0.2"
                                    Maximum="{TemplateBinding MaxZoom}"
                                    Minimum="{TemplateBinding EffectiveMinZoomValue}"
                                    SmallChange="0.05"
                                    TickFrequency="0"
                                    Value="{TemplateBinding Zoom,
                                                            Mode=TwoWay}" />
                                <Button
                                    Classes="Small"
                                    Padding="6,4"
                                    Command="{Binding ZoomIn, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="+" />
                                <Button
                                    Classes="Small"
                                    Padding="6,4"
                                    Command="{Binding FitToAll, RelativeSource={RelativeSource TemplatedParent}}">
                                    <fi:SymbolIcon
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="ArrowMinimize" />
                                </Button>
                                <Button
                                    Classes="Small"
                                    Padding="6,4"
                                    Command="{Binding FitToContent, RelativeSource={RelativeSource TemplatedParent}}">
                                    <fi:SymbolIcon
                                        FontSize="{StaticResource MediumFontSize}"
                                        Symbol="ArrowExpand" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
